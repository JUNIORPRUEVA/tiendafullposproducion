{
  "name": "@fulltech/api",
  "private": true,
  "version": "0.0.1",
  "main": "dist/main.js",
  "scripts": {
    "prestart": "prisma migrate deploy",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "prisma": "prisma",
    "prisma:migrate:dev": "prisma migrate dev --name init",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "integrity:check": "ts-node prisma/scripts/fix_integrity.ts --check",
    "integrity:fix": "ts-node prisma/scripts/fix_integrity.ts --fix",
    "test:integration:users": "ts-node scripts/integration-users-get.ts",
    "test:smoke:reservation-reminder": "ts-node scripts/smoke-reservation-reminder.ts",
    "auth:reset-password": "node scripts/reset-password.cjs",
    "test:smoke": "ts-node scripts/smoke-test.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.864.0",
    "@aws-sdk/s3-request-presigner": "^3.864.0",
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.8",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.8",
    "@prisma/client": "^5.22.0",
    "@types/pg": "^8.18.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pdfkit": "^0.16.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.13.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
