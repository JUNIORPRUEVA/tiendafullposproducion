DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
PORT=4000
CORS_ORIGIN=http://localhost:3000
UPLOAD_DIR=./uploads
# Nombre sugerido del volumen Docker para los uploads
# (ajusta en docker-compose si cambias el nombre)
UPLOAD_VOLUME_NAME=uploads_data
STORAGE_MODE=none
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379
REDIS_TTL_DEFAULT=60
REDIS_PREFIX=fulltech

# Storage (R2 / presigned uploads)
# Necesario para /storage/presign + /storage/confirm (subida directa al bucket desde Flutter).
#
# Nota (Web/PWA): si la app web hace PUT directo al bucket usando la URL presignada,
# el bucket debe tener CORS permitido para el dominio de la PWA (PUT + header Content-Type).
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Base pública para construir URLs de lectura (ideal: custom domain HTTPS del bucket/CDN)
R2_PUBLIC_BASE_URL=

# Límites (bytes) y expiración presign (segundos)
STORAGE_IMAGE_MAX_BYTES=5242880
STORAGE_VIDEO_MAX_BYTES=20971520
STORAGE_DOCUMENT_MAX_BYTES=10485760
STORAGE_PRESIGN_EXPIRES_SECONDS=900

# Seed (opcional)
ADMIN_EMAIL=admin@fulltech.local
ADMIN_PASSWORD=change-me
RUN_SEED=false
SELLER_PASSWORD=change-me
SELLER1_EMAIL=vendedor1@fulltech.local
SELLER2_EMAIL=vendedor2@fulltech.local

# Startup robustness (EasyPanel / contenedores)
RUN_MIGRATIONS=true
MIGRATION_MAX_RETRIES=10
MIGRATION_RETRY_DELAY_SECONDS=5
MIGRATION_STRICT=false

