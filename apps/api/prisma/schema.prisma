  serviceClosingInvoiceApprovedFor ServiceClosing[] @relation("ServiceClosingInvoiceApprovedFile")
  serviceClosingWarrantyApprovedFor ServiceClosing[] @relation("ServiceClosingWarrantyApprovedFile")
  serviceClosingInvoiceFinalFor ServiceClosing[] @relation("ServiceClosingInvoiceFinalFile")
  serviceClosingWarrantyFinalFor ServiceClosing[] @relation("ServiceClosingWarrantyFinalFile")

  @@index([serviceId])
  @@index([serviceId, createdAt])
  @@index([serviceId, kind])
  @@index([executionReportId])
  @@index([uploadedByUserId])
}

model ServiceOrder {
  id                String               @id @default(uuid()) @db.Uuid
  clientId          String               @db.Uuid @map("client_id")
  quotationId       String               @db.Uuid @map("quotation_id")
  category          ServiceOrderCategory
  serviceType       ServiceOrderType     @map("service_type")
  status            ServiceOrderStatus   @default(PENDIENTE)
  scheduledFor      DateTime?            @map("scheduled_for")
  finalizedAt       DateTime?            @map("finalized_at")
  technicianConfirmedAt   DateTime?      @map("technician_confirmed_at")
  technicianConfirmedById String?        @db.Uuid @map("technician_confirmed_by")
  technicalNote     String?              @db.Text @map("technical_note")
  extraRequirements String?              @db.Text @map("extra_requirements")
  parentOrderId     String?              @db.Uuid @map("parent_order_id")
  createdById       String               @db.Uuid @map("created_by")
  assignedToId      String?              @db.Uuid @map("assigned_to")
  lastStatusChangedAt DateTime           @default(now()) @map("last_status_changed_at")
  lastStatusChangedByUserId String?      @db.Uuid @map("last_status_changed_by_user_id")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  client      Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  quotation   Cotizacion      @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  parentOrder ServiceOrder?   @relation("ServiceOrderParent", fields: [parentOrderId], references: [id], onDelete: SetNull)
  childOrders ServiceOrder[]  @relation("ServiceOrderParent")
  createdBy   User            @relation("ServiceOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo  User?           @relation("ServiceOrderAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  lastStatusChangedBy User?   @relation("ServiceOrderLastStatusChangedBy", fields: [lastStatusChangedByUserId], references: [id], onDelete: SetNull)
  technicianConfirmedBy User? @relation("ServiceOrderConfirmedBy", fields: [technicianConfirmedById], references: [id], onDelete: SetNull)
  evidences   ServiceEvidence[]
  reports     ServiceReport[]
  statusHistory ServiceOrderStatusHistory[]
  documentFlow OrderDocumentFlow?
  payrollServiceCommissionRequests PayrollServiceCommissionRequest[]
  notificationJobs ServiceOrderNotificationJob[]

  @@index([clientId])
  @@index([quotationId])
  @@index([category])
  @@index([serviceType])
  @@index([status])
  @@index([scheduledFor])
  @@index([finalizedAt])
  @@index([createdById])
  @@index([assignedToId])
  @@index([lastStatusChangedAt])
  @@index([lastStatusChangedByUserId])
  @@index([technicianConfirmedById])
  @@index([parentOrderId])
  @@index([status, assignedToId])
  @@index([status, lastStatusChangedAt])
  @@index([clientId, createdAt])
  @@map("service_orders")
}

model ServiceOrderStatusHistory {
  id             String             @id @default(uuid()) @db.Uuid
  serviceOrderId String             @db.Uuid @map("service_order_id")
  previousStatus ServiceOrderStatus? @map("previous_status")
  nextStatus     ServiceOrderStatus @map("next_status")
  changedAt      DateTime           @default(now()) @map("changed_at")
  changedByUserId String?           @db.Uuid @map("changed_by_user_id")
  changedByUserName String?         @db.Text @map("changed_by_user_name")
  note           String?            @db.Text
  createdAt      DateTime           @default(now()) @map("created_at")

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  changedBy   User?         @relation("ServiceOrderStatusHistoryChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([serviceOrderId])
  @@index([serviceOrderId, changedAt])
  @@index([changedByUserId])
  @@map("service_order_status_history")
}

model ServiceEvidence {
  id             String              @id @default(uuid()) @db.Uuid
  serviceOrderId String              @db.Uuid @map("service_order_id")
  type           ServiceEvidenceType
  content        String              @db.Text
  createdById    String              @db.Uuid @map("created_by")
  createdAt      DateTime            @default(now()) @map("created_at")
  forPublicidad  Boolean             @default(false) @map("for_publicidad")

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ServiceEvidenceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([serviceOrderId])
  @@index([serviceOrderId, createdAt])
  @@index([type])
  @@index([createdById])
  @@map("service_evidences")
}

model ServiceReport {
  id             String   @id @default(uuid()) @db.Uuid
  serviceOrderId String   @db.Uuid @map("service_order_id")
  type           ServiceReportType @default(OTROS)
  report         String   @db.Text
  createdById    String   @db.Uuid @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ServiceReportCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([serviceOrderId])
  @@index([serviceOrderId, createdAt])
  @@index([type])
  @@index([createdById])
  @@map("service_reports")
}

model PublicidadImage {
  id           String   @id @default(uuid()) @db.Uuid
  url          String   @db.Text
  caption      String?
  uploadedById String   @db.Uuid @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  uploadedBy User @relation("PublicidadImageUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([uploadedById])
  @@index([createdAt])
  @@map("publicidad_images")
}

model OrderDocumentFlow {
  id               String                  @id @default(uuid()) @db.Uuid
  orderId          String                  @unique @db.Uuid @map("order_id")
  status           OrderDocumentFlowStatus @default(PENDING_PREPARATION)
  invoiceDraftJson Json?                   @map("invoice_draft_json")
  warrantyDraftJson Json?                  @map("warranty_draft_json")
  invoiceFinalUrl  String?                 @db.Text @map("invoice_final_url")
  warrantyFinalUrl String?                 @db.Text @map("warranty_final_url")
  preparedById     String?                 @db.Uuid @map("prepared_by")
  approvedById     String?                 @db.Uuid @map("approved_by")
  sentAt           DateTime?               @map("sent_at")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")

  order      ServiceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  preparedBy User?        @relation("OrderDocumentFlowPreparedBy", fields: [preparedById], references: [id], onDelete: SetNull)
  approvedBy User?        @relation("OrderDocumentFlowApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([preparedById])
  @@index([approvedById])
  @@index([sentAt])
  @@map("order_document_flows")
}

model Cotizacion {
  id              String   @id @default(uuid()) @db.Uuid
  createdByUserId String   @db.Uuid
  customerId      String?  @db.Uuid
  customerName    String
  customerPhone   String
  customerPhoneNormalized String @default("")
  note            String?  
  includeItbis    Boolean  @default(false)
  itbisRate       Decimal  @default(0.18) @db.Decimal(5, 4)
  globalDiscountAmount Decimal @default(0) @db.Decimal(12, 2)
  subtotal        Decimal  @db.Decimal(12, 2)
  subtotalCost    Decimal? @db.Decimal(12, 2)
  itbisAmount     Decimal  @db.Decimal(12, 2)
  totalCost       Decimal? @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  totalProfit     Decimal? @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

