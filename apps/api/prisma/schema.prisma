model User {
  id               String   @id @default(uuid()) @db.Uuid
  email            String   @unique
  passwordHash     String
  nombreCompleto   String
  telefono         String
  numeroFlota      String?
  telefonoFamiliar String?
  cedula           String?  @unique
  fotoCedulaUrl    String?
  fotoLicenciaUrl  String?
  fotoPersonalUrl  String?
  workContractSignatureUrl String?
  workContractSignedAt     DateTime?
  workContractVersion      String?
  workContractJobTitle     String?
  workContractSalary       String?
  workContractPaymentFrequency String?
  workContractPaymentMethod String?
  workContractWorkSchedule String?
  workContractWorkLocation String?
  workContractClauseOverrides Json?
  workContractCustomClauses String?
  workContractStartDate    DateTime?
  edad             Int
  tieneHijos       Boolean  @default(false)
  estaCasado       Boolean  @default(false)
  casaPropia       Boolean  @default(false)
  vehiculo         Boolean  @default(false)
  licenciaConducir Boolean  @default(false)
  fechaIngreso     DateTime?
  fechaNacimiento  DateTime?
  cuentaNominaPreferencial String?
  habilidades      Json?
  role             Role
  blocked          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clients Client[]
  payrollEmployees PayrollEmployee[] @relation("PayrollOwner")
  confirmedServiceOrders ServiceOrder[] @relation("ServiceOrderConfirmedBy")
  payrollProfile PayrollEmployee? @relation("PayrollEmployeeUser")
  payrollPeriods PayrollPeriod[]
  payrollEmployeeConfigs PayrollEmployeeConfig[]
  payrollEntries PayrollEntry[]
  employeeWarningsAssigned EmployeeWarning[] @relation("EmployeeWarningAssignedUser")
  employeeWarningsCreated EmployeeWarning[] @relation("EmployeeWarningCreatedByUser")
  employeeWarningsAnnulled EmployeeWarning[] @relation("EmployeeWarningAnnulledByUser")
  employeeWarningEvidencesUploaded EmployeeWarningEvidence[] @relation("EmployeeWarningEvidenceUploadedByUser")
  employeeWarningSignatures EmployeeWarningSignature[] @relation("EmployeeWarningSignatureEmployeeUser")
  employeeWarningAuditLogs EmployeeWarningAuditLog[] @relation("EmployeeWarningAuditActorUser")
  marketingStoriesApproved MarketingDailyStory[] @relation("MarketingStoryApprovedByUser")
  marketingActivityLogs MarketingActivityLog[] @relation("MarketingActivityLogActorUser")
  marketingFlowConfigsUpdated MarketingFlowConfig[] @relation("MarketingFlowUpdatedByUser")
  marketingResearchConfigs MarketingResearchConfig[] @relation("MarketingResearchConfigUpdatedByUser")
  marketingResearchesForced MarketingResearch[]      @relation("MarketingResearchForcedByUser")
  marketingResearchesApproved MarketingResearch[]    @relation("MarketingResearchApprovedByUser")
  payrollEmployeePeriodStatuses PayrollEmployeePeriodStatus[]
  payrollServiceCommissionRequestsOwned PayrollServiceCommissionRequest[] @relation("PayrollServiceCommissionOwner")
  payrollServiceCommissionRequests PayrollServiceCommissionRequest[] @relation("PayrollServiceCommissionTechnicianUser")
  payrollServiceCommissionRequestsCreated PayrollServiceCommissionRequest[] @relation("PayrollServiceCommissionCreatedByUser")
  payrollServiceCommissionRequestsReviewed PayrollServiceCommissionRequest[] @relation("PayrollServiceCommissionReviewedByUser")
  punches Punch[]
  sales Sale[]
  deletedSales Sale[] @relation("SaleDeletedBy")
  createdServices Service[] @relation("ServiceCreatedBy")
  assignedServices ServiceAssignment[]
  technicianServices Service[] @relation("ServiceTechnician")
  serviceStepsDone ServiceStep[] @relation("ServiceStepDoneBy")
  serviceUpdates ServiceUpdate[]
  servicePhaseHistory ServicePhaseHistory[]
  uploadedServiceFiles ServiceFile[]
  createdServiceOrders ServiceOrder[] @relation("ServiceOrderCreatedBy")
  assignedServiceOrders ServiceOrder[] @relation("ServiceOrderAssignedTo")
  statusChangedServiceOrders ServiceOrder[] @relation("ServiceOrderLastStatusChangedBy")
  serviceOrderStatusChanges ServiceOrderStatusHistory[] @relation("ServiceOrderStatusHistoryChangedBy")
  createdServiceEvidences ServiceEvidence[] @relation("ServiceEvidenceCreatedBy")
  createdServiceReports ServiceReport[] @relation("ServiceReportCreatedBy")
  publicidadImagesUploaded PublicidadImage[] @relation("PublicidadImageUploadedBy")
  preparedOrderDocumentFlows OrderDocumentFlow[] @relation("OrderDocumentFlowPreparedBy")
  approvedOrderDocumentFlows OrderDocumentFlow[] @relation("OrderDocumentFlowApprovedBy")
  serviceExecutionReports ServiceExecutionReport[]
  serviceExecutionChanges ServiceExecutionChange[]
  checklistExecutionsChecked ChecklistExecution[] @relation("ChecklistExecutionCheckedBy")
  cotizaciones Cotizacion[]
  location UserLocation?

  vehiculosPropios Vehiculo[] @relation("VehiculoPropietario")
  salidasTecnicas SalidaTecnica[]
  pagosCombustibleTecnicos PagoCombustibleTecnico[]

  notificationOutbox NotificationOutbox[]

  serviceClosingsApproved ServiceClosing[] @relation("ServiceClosingApprovedBy")
  serviceClosingsRejected ServiceClosing[] @relation("ServiceClosingRejectedBy")

  technicalVisits TechnicalVisit[] @relation("TechnicalVisitTechnician")

  crmCommercialCustomersAssigned CrmCommercialCustomer[] @relation("CrmCommercialResponsibleUser")
  crmCommercialCustomersCreated CrmCommercialCustomer[] @relation("CrmCommercialCreatedByUser")
  crmCommercialStatusChanges CrmCommercialStatusHistory[] @relation("CrmCommercialStatusChangedByUser")
  crmCommercialNotes CrmCommercialNote[] @relation("CrmCommercialNoteAuthorUser")
  crmCommercialActivitiesAssigned CrmCommercialActivity[] @relation("CrmCommercialActivityAssignedToUser")
  crmCommercialActivitiesCreated CrmCommercialActivity[] @relation("CrmCommercialActivityCreatedByUser")
  crmCommercialFollowupTasksAssigned  CrmCommercialFollowupTask[] @relation("CrmFollowupTaskAssignedUser")
  crmCommercialFollowupTasksCreated   CrmCommercialFollowupTask[] @relation("CrmFollowupTaskCreatedByUser")
  crmCommercialFollowupTasksCompleted CrmCommercialFollowupTask[] @relation("CrmFollowupTaskCompletedByUser")
  crmCommercialSettingsUpdated CrmCommercialSetting[] @relation("CrmCommercialSettingsUpdatedByUser")

  workEmployeeConfig WorkEmployeeConfig?
  warrantyProductConfigs WarrantyProductConfig[]
  whatsappInstance UserWhatsappInstance?

  @@map("users")
}

model EmployeeWarning {
  id                    String                       @id @default(uuid()) @db.Uuid
  companyId             String                       @map("company_id") @db.Uuid
  employeeUserId        String                       @map("employee_user_id") @db.Uuid
  createdByUserId       String                       @map("created_by_user_id") @db.Uuid
  warningNumber         String                       @map("warning_number")
  warningDate           DateTime                     @map("warning_date")
  incidentDate          DateTime                     @map("incident_date")
  title                 String
  category              EmployeeWarningCategory
  severity              EmployeeWarningSeverity
  legalBasis            String?                      @db.Text @map("legal_basis")
  internalRuleReference String?                      @db.Text @map("internal_rule_reference")
  description           String                       @db.Text
  employeeExplanation   String?                      @db.Text @map("employee_explanation")
  correctiveAction      String?                      @db.Text @map("corrective_action")
  consequenceNote       String?                      @db.Text @map("consequence_note")
  evidenceNotes         String?                      @db.Text @map("evidence_notes")
  status                EmployeeWarningStatus        @default(DRAFT)
  pdfUrl                String?                      @db.Text @map("pdf_url")
  signedPdfUrl          String?                      @db.Text @map("signed_pdf_url")
  createdAt             DateTime                     @default(now()) @map("created_at")
  updatedAt             DateTime                     @updatedAt @map("updated_at")
  submittedAt           DateTime?                    @map("submitted_at")
  signedAt              DateTime?                    @map("signed_at")
  refusedAt             DateTime?                    @map("refused_at")
  annulledAt            DateTime?                    @map("annulled_at")
  annulledByUserId      String?                      @map("annulled_by_user_id") @db.Uuid
  annulmentReason       String?                      @db.Text @map("annulment_reason")

  employeeUser          User                         @relation("EmployeeWarningAssignedUser", fields: [employeeUserId], references: [id], onDelete: Restrict)
  createdByUser         User                         @relation("EmployeeWarningCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  annulledByUser        User?                        @relation("EmployeeWarningAnnulledByUser", fields: [annulledByUserId], references: [id], onDelete: SetNull)
  evidences             EmployeeWarningEvidence[]
  signatures            EmployeeWarningSignature[]
  auditLogs             EmployeeWarningAuditLog[]

  @@index([companyId, employeeUserId])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@unique([companyId, warningNumber])
  @@map("employee_warnings")
}

model EmployeeWarningEvidence {
  id               String           @id @default(uuid()) @db.Uuid
  warningId        String           @map("warning_id") @db.Uuid
  fileUrl          String           @db.Text @map("file_url")
  fileName         String           @map("file_name")
  fileType         String           @map("file_type")
  storageKey       String?          @map("storage_key")
  uploadedByUserId String           @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at")

  warning          EmployeeWarning  @relation(fields: [warningId], references: [id], onDelete: Cascade)
  uploadedByUser   User             @relation("EmployeeWarningEvidenceUploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([warningId, createdAt])
  @@map("employee_warning_evidences")
}

model EmployeeWarningSignature {
  id                String                       @id @default(uuid()) @db.Uuid
  warningId         String                       @map("warning_id") @db.Uuid
  employeeUserId    String                       @map("employee_user_id") @db.Uuid
  signatureType     EmployeeWarningSignatureType @map("signature_type")
  signatureImageUrl String?                      @db.Text @map("signature_image_url")
  typedName         String                       @map("typed_name")
  comment           String?                      @db.Text
  ipAddress         String?                      @map("ip_address")
  deviceInfo        String?                      @db.Text @map("device_info")
  signedAt          DateTime                     @map("signed_at")
  createdAt         DateTime                     @default(now()) @map("created_at")

  warning           EmployeeWarning              @relation(fields: [warningId], references: [id], onDelete: Cascade)
  employeeUser      User                         @relation("EmployeeWarningSignatureEmployeeUser", fields: [employeeUserId], references: [id], onDelete: Restrict)

  @@index([warningId, signedAt])
  @@map("employee_warning_signatures")
}

model EmployeeWarningAuditLog {
  id          String           @id @default(uuid()) @db.Uuid
  warningId   String           @map("warning_id") @db.Uuid
  action      String
  actorUserId String?          @map("actor_user_id") @db.Uuid
  oldStatus   EmployeeWarningStatus? @map("old_status")
  newStatus   EmployeeWarningStatus? @map("new_status")
  metadataJson Json?           @map("metadata_json")
  createdAt   DateTime         @default(now()) @map("created_at")

  warning     EmployeeWarning  @relation(fields: [warningId], references: [id], onDelete: Cascade)
  actorUser   User?            @relation("EmployeeWarningAuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([warningId, createdAt])
  @@map("employee_warning_audit_logs")
}

model MarketingFlowConfig {
  id                   String   @id @default(uuid()) @db.Uuid
  companyId            String   @unique @map("company_id") @db.Uuid
  active               Boolean  @default(false)
  paused               Boolean  @default(false)
  dailyStoriesCount    Int      @default(3) @map("daily_stories_count")
  generationTime       String   @default("08:00") @map("generation_time")
  autoRegenerate       Boolean  @default(false) @map("auto_regenerate")
  regenerateAfterHours Int      @default(6) @map("regenerate_after_hours")
  targetCity           String?  @map("target_city")
  brandTone            String?  @map("brand_tone")
  priorityProducts     String[] @default([]) @map("priority_products")
  updatedByUserId      String?  @map("updated_by_user_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  updatedByUser User? @relation("MarketingFlowUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, active])
  @@map("marketing_flow_configs")
}

model MarketingDailyStory {
  id               String               @id @default(uuid()) @db.Uuid
  companyId        String               @map("company_id") @db.Uuid
  date             DateTime             @db.Date
  type             MarketingStoryType
  title            String
  shortText        String               @db.Text @map("short_text")
  longText         String?              @db.Text @map("long_text")
  hashtags         String[]             @default([])
  imagePrompt      String?              @db.Text @map("image_prompt")
  imageUrl         String?              @db.Text @map("image_url")
  status           MarketingStoryStatus @default(PENDING)
  generationAttempt Int                 @default(1) @map("generation_attempt")
  approvedByUserId String?              @map("approved_by_user_id") @db.Uuid
  approvedAt       DateTime?            @map("approved_at")
  rejectedAt       DateTime?            @map("rejected_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  researchId       String?              @map("research_id") @db.Uuid
  mediaAssetId     String?              @map("media_asset_id") @db.Uuid
  visualConcept    String?              @db.Text @map("visual_concept")
  designNotes      String?              @db.Text @map("design_notes")
  platformFormat   MarketingPlatformFormat @default(STORY_9_16) @map("platform_format")
  imageStatus      MarketingImageStatus @default(PENDING) @map("image_status")
  generatedImageUrl String?             @db.Text @map("generated_image_url")
  generatedImageProvider String?        @map("generated_image_provider")
  imageGenerationMetadata Json?         @map("image_generation_metadata")
  usedResearchAngle String?             @db.Text @map("used_research_angle")
  usedOffer        String?              @db.Text @map("used_offer")
  usedCTA          String?              @db.Text @map("used_cta")

  approvedByUser User? @relation("MarketingStoryApprovedByUser", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  research         MarketingResearch?   @relation(fields: [researchId], references: [id], onDelete: SetNull)
  mediaAsset       MarketingMediaAsset? @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@unique([companyId, date, type])
  @@index([companyId, date, status])
  @@index([companyId, status, updatedAt])
  @@index([companyId, imageStatus, date])
  @@index([companyId, mediaAssetId])
  @@map("marketing_daily_stories")
}

model MarketingMediaAsset {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  fileUrl         String   @db.Text @map("file_url")
  thumbnailUrl    String?  @db.Text @map("thumbnail_url")
  fileName        String   @map("file_name")
  mimeType        String   @map("mime_type")
  category        String
  relatedService  String?  @map("related_service")
  tags            Json?    
  description     String?  @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  isFeatured      Boolean  @default(false) @map("is_featured")
  useCount        Int      @default(0) @map("use_count")
  lastUsedAt      DateTime? @map("last_used_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  stories         MarketingDailyStory[]

  @@index([companyId, isActive, isFeatured])
  @@index([companyId, category, relatedService])
  @@index([companyId, useCount, lastUsedAt])
  @@map("marketing_media_assets")
}

model MarketingActivityLog {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  action      String
  description String   @db.Text
  userId      String?  @map("user_id") @db.Uuid
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation("MarketingActivityLogActorUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([companyId, action])
  @@map("marketing_activity_logs")
