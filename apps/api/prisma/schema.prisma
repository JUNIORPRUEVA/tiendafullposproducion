generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ASISTENTE
  MARKETING
  VENDEDOR
  TECNICO
}

enum PunchType {
  ENTRADA_LABOR
  SALIDA_LABOR
  SALIDA_PERMISO
  ENTRADA_PERMISO
  SALIDA_ALMUERZO
  ENTRADA_ALMUERZO
}

enum CloseType {
  CAPSULAS
  POS
  TIENDA
  PHYTOEMAGRY
}

enum DepositOrderStatus {
  PENDING
  EXECUTED
  CANCELLED
}

enum FiscalInvoiceKind {
  SALE_CARD
  SALE
  PURCHASE
}

enum PayableProviderKind {
  PERSON
  COMPANY
}

enum PayableFrequency {
  ONE_TIME
  MONTHLY
  BIWEEKLY
}

enum PayrollPeriodStatus {
  OPEN
  CLOSED
}

enum PayrollEntryType {
  AUSENCIA
  TARDE
  FERIADO_TRABAJADO
  COMISION_SERVICIO
  COMISION_VENTAS
  BONIFICACION
  PAGO_COMBUSTIBLE
  ADELANTO
  DESCUENTO
  OTRO
}

enum PayrollServiceCommissionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum PayrollPaymentStatus {
  DRAFT
  PAID
}

enum CompanyManualEntryKind {
  GENERAL_RULE
  ROLE_RULE
  POLICY
  WARRANTY_POLICY
  RESPONSIBILITY
  PRODUCT_SERVICE
  PRICE_RULE
  SERVICE_RULE
  MODULE_GUIDE
}

enum CompanyManualAudience {
  GENERAL
  ROLE_SPECIFIC
}

enum ServiceType {
  INSTALLATION
  MAINTENANCE
  WARRANTY
  POS_SUPPORT
  OTHER
}

enum ServiceStatus {
  RESERVED
  SURVEY
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  WARRANTY
  CLOSED
  CANCELLED
}

enum OrderType {
  RESERVA
  SERVICIO
  LEVANTAMIENTO
  GARANTIA
  MANTENIMIENTO
  INSTALACION
}

enum OrderState {
  PENDING
  CONFIRMED
  ASSIGNED
  IN_PROGRESS
  FINALIZED
  CANCELLED
  RESCHEDULED
}

enum ServiceAssignmentRole {
  LEAD
  ASSISTANT
}

enum ServiceUpdateType {
  STATUS_CHANGE
  NOTE
  SCHEDULE_CHANGE
  ASSIGNMENT_CHANGE
  PAYMENT_UPDATE
  STEP_UPDATE
  FILE_UPLOAD
  WARRANTY_CREATED
}

enum ServicePhaseType {
  RESERVA
  LEVANTAMIENTO
  INSTALACION
  MANTENIMIENTO
  GARANTIA
}

enum ChecklistTemplateType {
  HERRAMIENTAS
  PRODUCTOS
  INSTALACION
}

// Admin-only conceptual model (does NOT replace ServiceStatus/OrderState/ServicePhaseType).
// Used to keep panel administrativo consistent without breaking técnico.
enum AdminOrderPhase {
  RESERVA
  CONFIRMACION
  PROGRAMACION
  EJECUCION
  REVISION
  FACTURACION
  CIERRE
  CANCELADA
}

enum AdminOrderStatus {
  PENDIENTE
  CONFIRMADA
  ASIGNADA
  EN_CAMINO
  EN_PROCESO
  FINALIZADA
  REAGENDADA
  CANCELADA
  CERRADA
}

enum WorkShiftKind {
  NORMAL
  REDUCED
  SPECIAL
}

enum WorkAssignmentStatus {
  WORK
  DAY_OFF
  EXCEPTION_OFF
}

enum WorkScheduleExceptionType {
  HOLIDAY
  VACATION
  SICK
  LEAVE
  LICENSE
  ABSENCE
  BLOCKED_DAY
}

enum WorkWeekScheduleStatus {
  GENERATED
}

enum WorkScheduleAuditAction {
  GENERATE_WEEK
  REGENERATE_WEEK
  UPDATE_SETTINGS
  UPDATE_EMPLOYEE_CONFIG
  CREATE_EXCEPTION
  UPDATE_EXCEPTION
  DELETE_EXCEPTION
  MANUAL_MOVE_DAY_OFF
  MANUAL_SWAP_DAY_OFF
}

enum SalidaTecnicaEstado {
  INICIADA
  LLEGADA
  FINALIZADA
  APROBADA
  RECHAZADA
  PAGADA
}

enum PagoCombustibleTecnicoEstado {
  PENDIENTE
  PAGADO
  CANCELADO
}

enum NotificationChannel {
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

enum NotificationContentType {
  TEXT
  DOCUMENT
}

enum ServiceOrderNotificationJobKind {
  THIRTY_MINUTES_BEFORE
  FIFTEEN_MINUTES_PENDING
}

enum ServiceOrderNotificationJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ServiceClosingApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ServiceClosingSignatureStatus {
  PENDING
  SIGNED
  SKIPPED
}

enum WarrantyDurationUnit {
  DAYS
  MONTHS
  YEARS
}

enum ServiceOrderCategory {
  CAMARA          @map("camara")
  MOTOR_PORTON    @map("motor_porton")
  ALARMA          @map("alarma")
  CERCO_ELECTRICO @map("cerco_electrico")
  INTERCOM        @map("intercom")
  PUNTO_VENTA     @map("punto_venta")

  @@map("service_order_category")
}

enum ServiceOrderType {
  INSTALACION   @map("instalacion")
  MANTENIMIENTO @map("mantenimiento")
  LEVANTAMIENTO @map("levantamiento")
  GARANTIA      @map("garantia")

  @@map("service_order_type")
}

enum ServiceOrderStatus {
  PENDIENTE  @map("pendiente")
  EN_PROCESO @map("en_proceso")
  POSPUESTA  @map("pospuesta")
  FINALIZADO @map("finalizado")
  CANCELADO  @map("cancelado")

  @@map("service_order_status")
}

enum OrderDocumentFlowStatus {
  PENDING_PREPARATION   @map("pending_preparation")
  READY_FOR_REVIEW      @map("ready_for_review")
  READY_FOR_FINALIZATION @map("ready_for_finalization")
  APPROVED              @map("approved")
  REJECTED              @map("rejected")
  SENT                  @map("sent")

  @@map("order_document_flow_status")
}

enum ServiceEvidenceType {
  REFERENCIA_TEXTO  @map("referencia_texto")
  REFERENCIA_IMAGEN @map("referencia_imagen")
  REFERENCIA_VIDEO  @map("referencia_video")
  EVIDENCIA_TEXTO   @map("evidencia_texto")
  EVIDENCIA_IMAGEN  @map("evidencia_imagen")
  EVIDENCIA_VIDEO   @map("evidencia_video")

  @@map("service_evidence_type")
}

enum ServiceReportType {
  REQUERIMIENTO_CLIENTE @map("requerimiento_cliente")
  SERVICIO_FINALIZADO   @map("servicio_finalizado")
  OTROS                 @map("otros")

  @@map("service_report_type")
}

model User {
  id               String   @id @default(uuid()) @db.Uuid
  email            String   @unique
  passwordHash     String
  nombreCompleto   String
  telefono         String
  numeroFlota      String?
  telefonoFamiliar String?
  cedula           String?  @unique
  fotoCedulaUrl    String?
  fotoLicenciaUrl  String?
  fotoPersonalUrl  String?
  workContractSignatureUrl String?
  workContractSignedAt     DateTime?
  workContractVersion      String?
  workContractJobTitle     String?
  workContractSalary       String?
  workContractPaymentFrequency String?
  workContractPaymentMethod String?
  workContractWorkSchedule String?
  workContractWorkLocation String?
  workContractClauseOverrides Json?
  workContractCustomClauses String?
  workContractStartDate    DateTime?
  edad             Int
  tieneHijos       Boolean  @default(false)
  estaCasado       Boolean  @default(false)
  casaPropia       Boolean  @default(false)
  vehiculo         Boolean  @default(false)
  licenciaConducir Boolean  @default(false)
  fechaIngreso     DateTime?
  fechaNacimiento  DateTime?
  cuentaNominaPreferencial String?
  habilidades      Json?
  role             Role
  blocked          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clients Client[]
  payrollEmployees PayrollEmployee[] @relation("PayrollOwner")
  confirmedServiceOrders ServiceOrder[] @relation("ServiceOrderConfirmedBy")
  payrollProfile PayrollEmployee? @relation("PayrollEmployeeUser")
  payrollPeriods PayrollPeriod[]
  payrollEmployeeConfigs PayrollEmployeeConfig[]
  payrollEntries PayrollEntry[]
  payrollEmployeePeriodStatuses PayrollEmployeePeriodStatus[]
  payrollServiceCommissionRequestsOwned PayrollServiceCommissionRequest[] @relation("PayrollServiceCommissionOwner")
  payrollServiceCommissionRequests PayrollServiceCommissionRequest[] @relation("PayrollServiceCommissionTechnicianUser")
  payrollServiceCommissionRequestsCreated PayrollServiceCommissionRequest[] @relation("PayrollServiceCommissionCreatedByUser")
  payrollServiceCommissionRequestsReviewed PayrollServiceCommissionRequest[] @relation("PayrollServiceCommissionReviewedByUser")
  punches Punch[]
  sales Sale[]
  deletedSales Sale[] @relation("SaleDeletedBy")
  createdServices Service[] @relation("ServiceCreatedBy")
  assignedServices ServiceAssignment[]
  technicianServices Service[] @relation("ServiceTechnician")
  serviceStepsDone ServiceStep[] @relation("ServiceStepDoneBy")
  serviceUpdates ServiceUpdate[]
  servicePhaseHistory ServicePhaseHistory[]
  uploadedServiceFiles ServiceFile[]
  createdServiceOrders ServiceOrder[] @relation("ServiceOrderCreatedBy")
  assignedServiceOrders ServiceOrder[] @relation("ServiceOrderAssignedTo")
  createdServiceEvidences ServiceEvidence[] @relation("ServiceEvidenceCreatedBy")
  createdServiceReports ServiceReport[] @relation("ServiceReportCreatedBy")
  preparedOrderDocumentFlows OrderDocumentFlow[] @relation("OrderDocumentFlowPreparedBy")
  approvedOrderDocumentFlows OrderDocumentFlow[] @relation("OrderDocumentFlowApprovedBy")
  serviceExecutionReports ServiceExecutionReport[]
  serviceExecutionChanges ServiceExecutionChange[]
  checklistExecutionsChecked ChecklistExecution[] @relation("ChecklistExecutionCheckedBy")
  cotizaciones Cotizacion[]
  location UserLocation?

  vehiculosPropios Vehiculo[] @relation("VehiculoPropietario")
  salidasTecnicas SalidaTecnica[]
  pagosCombustibleTecnicos PagoCombustibleTecnico[]

  notificationOutbox NotificationOutbox[]

  serviceClosingsApproved ServiceClosing[] @relation("ServiceClosingApprovedBy")
  serviceClosingsRejected ServiceClosing[] @relation("ServiceClosingRejectedBy")

  technicalVisits TechnicalVisit[] @relation("TechnicalVisitTechnician")

  workEmployeeConfig WorkEmployeeConfig?
  warrantyProductConfigs WarrantyProductConfig[]
  whatsappInstance UserWhatsappInstance?

  @@map("users")
}

model UserWhatsappInstance {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @db.Uuid @map("user_id")
  instanceName   String   @unique @map("instance_name")
  status         String   @default("pending")
  phoneNumber    String?  @map("phone_number")
  webhookEnabled Boolean  @default(false) @map("webhook_enabled")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations WhatsappConversation[]

  @@map("user_whatsapp_instances")
}

// ─── WhatsApp CRM Inbox ────────────────────────────────────────────────────

enum WhatsappMessageDirection {
  INCOMING
  OUTGOING

  @@map("whatsapp_message_direction")
}

enum WhatsappMessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  STICKER
  OTHER

  @@map("whatsapp_message_type")
}

model WhatsappConversation {
  id            String    @id @default(uuid()) @db.Uuid
  instanceId    String    @db.Uuid @map("instance_id")
  remoteJid     String    @map("remote_jid")
  remotePhone   String?   @map("remote_phone")
  remoteName    String?   @map("remote_name")
  lastMessageAt DateTime? @map("last_message_at")
  unreadCount   Int       @default(0) @map("unread_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  instance UserWhatsappInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  messages WhatsappMessage[]

  @@unique([instanceId, remoteJid])
  @@index([instanceId, lastMessageAt(sort: Desc)])
  @@map("whatsapp_conversations")
}

model WhatsappMessage {
  id             String                   @id @default(uuid()) @db.Uuid
  conversationId String                   @db.Uuid @map("conversation_id")
  evolutionId    String?                  @unique @map("evolution_id")
  direction      WhatsappMessageDirection
  messageType    WhatsappMessageType      @default(TEXT) @map("message_type")
  body           String?                  @db.Text
  mediaUrl       String?                  @db.Text @map("media_url")
  mediaMimeType  String?                  @map("media_mime_type")
  caption        String?                  @db.Text
  senderName     String?                  @map("sender_name")
  sentAt         DateTime                 @map("sent_at")
  createdAt      DateTime                 @default(now()) @map("created_at")
  rawPayload     Json?                    @map("raw_payload")

  conversation WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt(sort: Desc)])
  @@map("whatsapp_messages")
}

model UserLocation {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @db.Uuid
  latitude       Float
  longitude      Float
  accuracyMeters Float?
  altitudeMeters Float?
  headingDegrees Float?
  speedMps       Float?
  recordedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
  @@map("user_locations")
}

model AppConfig {
  id           String   @id @default("global")
  companyName  String   @default("")
  rnc          String   @default("")
  phone        String   @default("")
  phonePreferential String @default("") @map("phone_preferential")
  address      String   @default("")
  description  String   @default("")
  instagramUrl String   @default("") @map("instagram_url")
  facebookUrl  String   @default("") @map("facebook_url")
  websiteUrl   String   @default("") @map("website_url")
  gpsLocationUrl String @default("") @map("gps_location_url")
  businessHours  String @default("") @map("business_hours")
  bankAccounts   Json   @default("[]") @map("bank_accounts")
  legalRepresentativeName         String  @default("") @map("legal_representative_name")
  legalRepresentativeCedula       String  @default("") @map("legal_representative_cedula")
  legalRepresentativeRole         String  @default("") @map("legal_representative_role")
  legalRepresentativeNationality  String  @default("") @map("legal_representative_nationality")
  legalRepresentativeCivilStatus  String  @default("") @map("legal_representative_civil_status")
  logoBase64   String?
  openAiApiKey String?
  openAiModel  String   @default("gpt-4o-mini")
  evolutionApiBaseUrl      String  @default("") @map("evolution_api_base_url")
  evolutionApiInstanceName String  @default("") @map("evolution_api_instance_name")
  evolutionApiApiKey       String? @map("evolution_api_api_key")
  whatsappWebhookEnabled   Boolean @default(false) @map("whatsapp_webhook_enabled")
  operationsTechCanViewAllServices Boolean @default(false) @map("operations_tech_can_view_all_services")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("app_config")
}

model ServiceExecutionReport {
  id                String           @id @default(uuid()) @db.Uuid
  serviceId         String           @db.Uuid @map("service_id")
  technicianId      String           @db.Uuid @map("technician_id")
  phase             ServicePhaseType
  arrivedAt         DateTime?        @map("arrived_at")
  startedAt         DateTime?        @map("started_at")
  finishedAt        DateTime?        @map("finished_at")
  notes             String?
  checklistData     Json?            @map("checklist_data")
  phaseSpecificData Json?            @map("phase_specific_data")
  clientApproved    Boolean          @default(false) @map("client_approved")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  service          Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  technician       User             @relation(fields: [technicianId], references: [id], onDelete: Restrict)
  changes          ServiceExecutionChange[]
  files            ServiceFile[]

  @@unique([serviceId, technicianId])
  @@index([serviceId])
  @@index([technicianId])
  @@index([updatedAt])
  @@map("service_execution_reports")
}

model ServiceExecutionChange {
  id                String   @id @default(uuid()) @db.Uuid
  serviceId         String   @db.Uuid @map("service_id")
  executionReportId String   @db.Uuid @map("execution_report_id")
  createdByUserId   String   @db.Uuid @map("created_by_user_id")
  type              String
  description       String
  quantity          Decimal? @db.Decimal(12, 3)
  extraCost         Decimal? @db.Decimal(12, 2) @map("extra_cost")
  clientApproved    Boolean? @map("client_approved")
  note              String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  service          Service               @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  executionReport  ServiceExecutionReport @relation(fields: [executionReportId], references: [id], onDelete: Cascade)
  createdBy        User                  @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([serviceId, createdAt])
  @@index([executionReportId])
  @@index([createdByUserId])
  @@map("service_execution_changes")
}

model ServiceCategory {
  id        String              @id @default(uuid()) @db.Uuid
  name      String
  code      String              @unique
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  services  Service[]
  templates ChecklistTemplate[]
  warrantyConfigs WarrantyProductConfig[]

  @@index([name])
  @@map("service_categories")
}

model ServicePhase {
  id         String              @id @default(uuid()) @db.Uuid
  name       String
  code       String              @unique
  orderIndex Int                 @default(0) @map("order_index")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  templates  ChecklistTemplate[]

  @@index([orderIndex])
  @@index([name])
  @@map("service_phases")
}

model ChecklistTemplate {
  id         String            @id @default(uuid()) @db.Uuid
  categoryId String            @db.Uuid @map("category_id")
  phaseId    String            @db.Uuid @map("phase_id")
  type       ChecklistTemplateType
  title      String
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  category   ServiceCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  phase      ServicePhase      @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  items      ChecklistItem[]
  executions ChecklistExecution[]

  @@unique([categoryId, phaseId, type])
  @@index([categoryId])
  @@index([phaseId])
  @@index([categoryId, phaseId])
  @@map("checklist_templates")
}

model ChecklistItem {
  id         String                 @id @default(uuid()) @db.Uuid
  templateId String                 @db.Uuid @map("template_id")
  label      String
  isRequired Boolean                @default(true) @map("is_required")
  orderIndex Int                    @default(0) @map("order_index")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @updatedAt @map("updated_at")

  template   ChecklistTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  executions ChecklistExecution[]

  @@index([templateId])
  @@index([templateId, orderIndex])
  @@map("checklist_items")
}

model ChecklistExecution {
  id              String            @id @default(uuid()) @db.Uuid
  serviceOrderId  String            @db.Uuid @map("service_order_id")
  templateId      String            @db.Uuid @map("template_id")
  checklistItemId String            @db.Uuid @map("checklist_item_id")
  isChecked       Boolean           @default(false) @map("is_checked")
  checkedAt       DateTime?         @map("checked_at")
  checkedByUserId String?           @db.Uuid @map("checked_by")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  service         Service           @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  template        ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  checklistItem   ChecklistItem     @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)
  checkedBy       User?             @relation("ChecklistExecutionCheckedBy", fields: [checkedByUserId], references: [id], onDelete: SetNull)

  @@unique([serviceOrderId, checklistItemId])
  @@index([serviceOrderId])
  @@index([templateId])
  @@index([checklistItemId])
  @@index([checkedByUserId])
  @@map("checklist_executions")
}

model NotificationOutbox {
  id                String              @id @default(uuid()) @db.Uuid
  channel           NotificationChannel @default(WHATSAPP)
  status            NotificationStatus  @default(PENDING)
  contentType       NotificationContentType @default(TEXT) @map("content_type")
  templateKey       String              @map("template_key")
  dedupeKey         String?             @unique @map("dedupe_key")
  messageText       String              @map("message_text")
  mediaBase64       String?             @db.Text @map("media_base64")
  mediaFileName     String?             @map("media_file_name")
  mediaMimeType     String?             @map("media_mime_type")
  payload           Json?
  recipientUserId   String?             @db.Uuid @map("recipient_user_id")
  toNumber          String              @map("to_number")
  toNumberNormalized String             @default("") @map("to_number_normalized")
  attempts          Int                 @default(0)
  nextAttemptAt     DateTime            @default(now()) @map("next_attempt_at")
  lockedAt          DateTime?           @map("locked_at")
  lockedBy          String?             @map("locked_by")
  lastError         String?             @map("last_error")
  lastStatusCode    Int?                @map("last_status_code")
  sentAt            DateTime?           @map("sent_at")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  recipientUser User? @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([status, nextAttemptAt])
  @@index([lockedAt])
  @@map("notification_outbox")
}

model ServiceOrderNotificationJob {
  id          String                            @id @default(uuid()) @db.Uuid
  orderId     String                            @db.Uuid @map("order_id")
  kind        ServiceOrderNotificationJobKind
  status      ServiceOrderNotificationJobStatus @default(PENDING)
  dedupeKey   String                            @unique @map("dedupe_key")
  runAt       DateTime                          @map("run_at")
  payload     Json?
  attempts    Int                               @default(0)
  lockedAt    DateTime?                         @map("locked_at")
  lockedBy    String?                           @map("locked_by")
  lastError   String?                           @map("last_error")
  completedAt DateTime?                         @map("completed_at")
  createdAt   DateTime                          @default(now()) @map("created_at")
  updatedAt   DateTime                          @updatedAt @map("updated_at")

  order ServiceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status, runAt])
  @@index([lockedAt])
  @@map("service_order_notification_jobs")
}

model Punch {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @db.Uuid
  type      PunchType
  timestamp DateTime   @default(now())
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String
  categoria String
  costo     Decimal  @db.Decimal(12, 2)
  precio    Decimal  @db.Decimal(12, 2)
  imagen    String?

  saleItems SaleItem[]
  cotizacionItems CotizacionItem[]
}

model Client {
  id        String   @id @default(uuid()) @db.Uuid
  ownerId   String   @db.Uuid
  nombre    String
  telefono  String
  phoneNormalized String @default("")
  email     String?
  direccion String?
  notas     String?
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  locationUrl String? @map("location_url")
  lastActivityAt DateTime?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sales Sale[]
  services Service[]
  serviceOrders ServiceOrder[]
  cotizaciones Cotizacion[]

  @@index([ownerId])
  @@index([ownerId, nombre])
  @@index([ownerId, telefono])
  @@index([phoneNormalized])
  @@index([lastActivityAt])
  @@index([latitude, longitude])
}

model Sale {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  customerId       String?   @db.Uuid
  saleDate         DateTime  @default(now())
