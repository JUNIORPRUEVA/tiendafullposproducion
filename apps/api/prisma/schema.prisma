model ServiceOrder {
  id                String               @id @default(uuid()) @db.Uuid
  clientId          String               @db.Uuid @map("client_id")
  quotationId       String               @db.Uuid @map("quotation_id")
  category          ServiceOrderCategory
  serviceType       ServiceOrderType     @map("service_type")
  status            ServiceOrderStatus   @default(PENDIENTE)
  scheduledFor      DateTime?            @map("scheduled_for")
  finalizedAt       DateTime?            @map("finalized_at")
  technicianConfirmedAt   DateTime?      @map("technician_confirmed_at")
  technicianConfirmedById String?        @db.Uuid @map("technician_confirmed_by")
  technicalNote     String?              @db.Text @map("technical_note")
  extraRequirements String?              @db.Text @map("extra_requirements")
  parentOrderId     String?              @db.Uuid @map("parent_order_id")
  createdById       String               @db.Uuid @map("created_by")
  assignedToId      String?              @db.Uuid @map("assigned_to")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  client      Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  quotation   Cotizacion      @relation(fields: [quotationId], references: [id], onDelete: Restrict)
  parentOrder ServiceOrder?   @relation("ServiceOrderParent", fields: [parentOrderId], references: [id], onDelete: SetNull)
  childOrders ServiceOrder[]  @relation("ServiceOrderParent")
  createdBy   User            @relation("ServiceOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedTo  User?           @relation("ServiceOrderAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  technicianConfirmedBy User? @relation("ServiceOrderConfirmedBy", fields: [technicianConfirmedById], references: [id], onDelete: SetNull)
  evidences   ServiceEvidence[]
  reports     ServiceReport[]
  documentFlow OrderDocumentFlow?
  payrollServiceCommissionRequests PayrollServiceCommissionRequest[]
  notificationJobs ServiceOrderNotificationJob[]

  @@index([clientId])
  @@index([quotationId])
  @@index([category])
  @@index([serviceType])
  @@index([status])
  @@index([scheduledFor])
  @@index([finalizedAt])
  @@index([createdById])
  @@index([assignedToId])
  @@index([technicianConfirmedById])
  @@index([parentOrderId])
  @@index([status, assignedToId])
  @@index([clientId, createdAt])
  @@map("service_orders")
}

model ServiceEvidence {
  id             String              @id @default(uuid()) @db.Uuid
