  employeeConfig WorkEmployeeConfig @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([weekScheduleId, userId, date])
  @@index([weekScheduleId])
  @@index([userId])
  @@index([date])
  @@index([weekday])
  @@map("work_day_assignments")
}

model WorkScheduleAuditLog {
  id            String                 @id @default(uuid()) @db.Uuid
  action        WorkScheduleAuditAction
  actorUserId   String?                @db.Uuid @map("actor_user_id")
  actorUserName String?                @map("actor_user_name")
  targetUserId  String?                @db.Uuid @map("target_user_id")
  weekStartDate DateTime?              @map("week_start_date")
  dateAffected  DateTime?              @map("date_affected")
  reason        String?
  before        Json?
  after         Json?
  createdAt     DateTime               @default(now())

  @@index([action])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([weekStartDate])
  @@index([createdAt])
  @@map("work_schedule_audit_logs")
}

model AiAssistantConversationTurn {
  id                String   @id @default(uuid()) @db.Uuid
  ownerId           String   @db.Uuid @map("owner_id")
  userId            String   @db.Uuid @map("user_id")
  module            String   @default("general")
  route             String?
  entityType        String?  @map("entity_type")
  entityId          String?  @map("entity_id")
  userMessage       String   @map("user_message")
  assistantResponse String   @map("assistant_response")
  responseSource    String   @default("rules-only") @map("response_source")
  denied            Boolean  @default(false)
  citations         Json?
  createdAt         DateTime @default(now())

  @@index([ownerId, userId, createdAt])
  @@index([ownerId, module, createdAt])
  @@map("ai_assistant_conversation_turns")
}

model AiAssistantMemory {
  id           String   @id @default(uuid()) @db.Uuid
  ownerId      String   @db.Uuid @map("owner_id")
  userId       String   @db.Uuid @map("user_id")
  scope        String   @default("user")
  module       String   @default("general")
  topicKey     String   @map("topic_key")
  title        String
  summary      String
  keywords     Json?
  sourceCount  Int      @default(1) @map("source_count")
  lastSourceAt DateTime @default(now()) @map("last_source_at")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ownerId, userId, scope, topicKey])
  @@index([ownerId, userId, module])
  @@index([ownerId, userId, lastSourceAt])
  @@map("ai_assistant_memories")
}
