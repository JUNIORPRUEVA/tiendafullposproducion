generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ASISTENTE
  MARKETING
  VENDEDOR
  TECNICO
}

enum PunchType {
  ENTRADA_LABOR
  SALIDA_LABOR
  SALIDA_PERMISO
  ENTRADA_PERMISO
  SALIDA_ALMUERZO
  ENTRADA_ALMUERZO
}

enum CloseType {
  CAPSULAS
  POS
  TIENDA
}

enum DepositOrderStatus {
  PENDING
  EXECUTED
  CANCELLED
}

enum FiscalInvoiceKind {
  SALE
  PURCHASE
}

enum PayableProviderKind {
  PERSON
  COMPANY
}

enum PayableFrequency {
  ONE_TIME
  MONTHLY
  BIWEEKLY
}

enum PayrollPeriodStatus {
  OPEN
  CLOSED
}

enum PayrollEntryType {
  AUSENCIA
  TARDE
  COMISION_SERVICIO
  COMISION_VENTAS
  BONIFICACION
  PAGO_COMBUSTIBLE
  ADELANTO
  DESCUENTO
  OTRO
}

enum ServiceType {
  INSTALLATION
  MAINTENANCE
  WARRANTY
  POS_SUPPORT
  OTHER
}

enum ServiceStatus {
  RESERVED
  SURVEY
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  WARRANTY
  CLOSED
  CANCELLED
}

enum OrderType {
  RESERVA
  SERVICIO
  LEVANTAMIENTO
  GARANTIA
  MANTENIMIENTO
  INSTALACION
}

enum OrderState {
  PENDING
  CONFIRMED
  ASSIGNED
  IN_PROGRESS
  FINALIZED
  CANCELLED
  RESCHEDULED
}

enum ServiceAssignmentRole {
  LEAD
  ASSISTANT
}

enum ServiceUpdateType {
  STATUS_CHANGE
  NOTE
  SCHEDULE_CHANGE
  ASSIGNMENT_CHANGE
  PAYMENT_UPDATE
  STEP_UPDATE
  FILE_UPLOAD
  WARRANTY_CREATED
}

enum ServicePhaseType {
  RESERVA
  LEVANTAMIENTO
  INSTALACION
  MANTENIMIENTO
  GARANTIA
}

enum WorkShiftKind {
  NORMAL
  REDUCED
  SPECIAL
}

enum WorkAssignmentStatus {
  WORK
  DAY_OFF
  EXCEPTION_OFF
}

enum WorkScheduleExceptionType {
  HOLIDAY
  VACATION
  SICK
  LEAVE
  LICENSE
  ABSENCE
  BLOCKED_DAY
}

enum WorkWeekScheduleStatus {
  GENERATED
}

enum WorkScheduleAuditAction {
  GENERATE_WEEK
  REGENERATE_WEEK
  UPDATE_SETTINGS
  UPDATE_EMPLOYEE_CONFIG
  CREATE_EXCEPTION
  UPDATE_EXCEPTION
  DELETE_EXCEPTION
  MANUAL_MOVE_DAY_OFF
  MANUAL_SWAP_DAY_OFF
}

enum SalidaTecnicaEstado {
  INICIADA
  LLEGADA
  FINALIZADA
  APROBADA
  RECHAZADA
  PAGADA
}

enum PagoCombustibleTecnicoEstado {
  PENDIENTE
  PAGADO
  CANCELADO
}

model User {
  id               String   @id @default(uuid()) @db.Uuid
  email            String   @unique
  passwordHash     String
  nombreCompleto   String
  telefono         String
  telefonoFamiliar String?
  cedula           String?  @unique
  fotoCedulaUrl    String?
  fotoLicenciaUrl  String?
  fotoPersonalUrl  String?
  workContractSignatureUrl String?
  workContractSignedAt     DateTime?
  workContractVersion      String?
  workContractJobTitle     String?
  workContractSalary       String?
  workContractPaymentFrequency String?
  workContractPaymentMethod String?
  workContractWorkSchedule String?
  workContractWorkLocation String?
  workContractClauseOverrides Json?
  workContractCustomClauses String?
  workContractStartDate    DateTime?
  edad             Int
  tieneHijos       Boolean  @default(false)
  estaCasado       Boolean  @default(false)
  casaPropia       Boolean  @default(false)
  vehiculo         Boolean  @default(false)
  licenciaConducir Boolean  @default(false)
  fechaIngreso     DateTime?
  fechaNacimiento  DateTime?
  cuentaNominaPreferencial String?
  habilidades      Json?
  role             Role
  blocked          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clients Client[]
  payrollEmployees PayrollEmployee[] @relation("PayrollOwner")
  payrollProfile PayrollEmployee? @relation("PayrollEmployeeUser")
  payrollPeriods PayrollPeriod[]
  payrollEmployeeConfigs PayrollEmployeeConfig[]
  payrollEntries PayrollEntry[]
  punches Punch[]
  sales Sale[]
  deletedSales Sale[] @relation("SaleDeletedBy")
  createdServices Service[] @relation("ServiceCreatedBy")
  assignedServices ServiceAssignment[]
  technicianServices Service[] @relation("ServiceTechnician")
  serviceStepsDone ServiceStep[] @relation("ServiceStepDoneBy")
  serviceUpdates ServiceUpdate[]
  servicePhaseHistory ServicePhaseHistory[]
  uploadedServiceFiles ServiceFile[]
  cotizaciones Cotizacion[]
  location UserLocation?

  vehiculosPropios Vehiculo[] @relation("VehiculoPropietario")
  salidasTecnicas SalidaTecnica[]
  pagosCombustibleTecnicos PagoCombustibleTecnico[]

  workEmployeeConfig WorkEmployeeConfig?

  @@map("users")
}

model UserLocation {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @db.Uuid
  latitude       Float
  longitude      Float
  accuracyMeters Float?
  altitudeMeters Float?
  headingDegrees Float?
  speedMps       Float?
  recordedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
  @@map("user_locations")
}

model AppConfig {
  id           String   @id @default("global")
  companyName  String   @default("")
  rnc          String   @default("")
  phone        String   @default("")
  address      String   @default("")
  legalRepresentativeName         String  @default("") @map("legal_representative_name")
  legalRepresentativeCedula       String  @default("") @map("legal_representative_cedula")
  legalRepresentativeRole         String  @default("") @map("legal_representative_role")
  legalRepresentativeNationality  String  @default("") @map("legal_representative_nationality")
  legalRepresentativeCivilStatus  String  @default("") @map("legal_representative_civil_status")
  logoBase64   String?
  openAiApiKey String?
  openAiModel  String   @default("gpt-4o-mini")
  evolutionApiBaseUrl      String  @default("") @map("evolution_api_base_url")
  evolutionApiInstanceName String  @default("") @map("evolution_api_instance_name")
  evolutionApiApiKey       String? @map("evolution_api_api_key")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("app_config")
}

model Punch {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @db.Uuid
  type      PunchType
  timestamp DateTime   @default(now())
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String
  categoria String
  costo     Decimal  @db.Decimal(12, 2)
  precio    Decimal  @db.Decimal(12, 2)
  imagen    String?

  saleItems SaleItem[]
  cotizacionItems CotizacionItem[]
}

model Client {
  id        String   @id @default(uuid()) @db.Uuid
  ownerId   String   @db.Uuid
  nombre    String
  telefono  String
  email     String?
  direccion String?
  notas     String?
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sales Sale[]
  services Service[]
  cotizaciones Cotizacion[]

  @@index([ownerId])
  @@index([ownerId, nombre])
  @@index([ownerId, telefono])
}

model Sale {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  customerId       String?   @db.Uuid
  saleDate         DateTime  @default(now())
  note             String?
  totalSold        Decimal   @db.Decimal(12, 2)
  totalCost        Decimal   @db.Decimal(12, 2)
  totalProfit      Decimal   @db.Decimal(12, 2)
  commissionRate   Decimal   @default(0.10) @db.Decimal(5, 4)
  commissionAmount Decimal   @db.Decimal(12, 2)
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?
  deletedById      String?   @db.Uuid
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer  Client?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  deletedBy User?     @relation("SaleDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  items     SaleItem[]

  @@index([userId])
  @@index([customerId])
  @@index([saleDate])
  @@index([isDeleted])
}

model SaleItem {
  id                   String   @id @default(uuid()) @db.Uuid
  saleId               String   @db.Uuid
  productId            String?  @db.Uuid
  productNameSnapshot  String
  productImageSnapshot String?
  qty                  Decimal  @db.Decimal(12, 3)
  priceSoldUnit        Decimal  @db.Decimal(12, 2)
  costUnitSnapshot     Decimal  @db.Decimal(12, 2)
  subtotalSold         Decimal  @db.Decimal(12, 2)
  subtotalCost         Decimal  @db.Decimal(12, 2)
  profit               Decimal  @db.Decimal(12, 2)
  createdAt            DateTime @default(now())

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([productId])
}

model Close {
  id            String    @id @default(uuid()) @db.Uuid
  type          CloseType
  date          DateTime  @default(now())
  status        String    // pending/draft/closed
  cash          Decimal   @db.Decimal(12, 2)
  transfer      Decimal   @db.Decimal(12, 2)
  transferBank  String?
  card          Decimal   @db.Decimal(12, 2)
  expenses      Decimal   @db.Decimal(12, 2)
  cashDelivered Decimal   @db.Decimal(12, 2)
  createdById   String?   @db.Uuid
  createdByName String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([date])
  @@index([type])
  @@index([createdById])
}

model DepositOrder {
  id                String             @id @default(uuid()) @db.Uuid
  windowFrom        DateTime
  windowTo          DateTime
  bankName          String
  reserveAmount     Decimal            @db.Decimal(12, 2)
  totalAvailableCash Decimal           @db.Decimal(12, 2)
  depositTotal      Decimal            @db.Decimal(12, 2)
  closesCountByType Json
  depositByType     Json
  accountByType     Json
  status            DepositOrderStatus @default(PENDING)
  createdById       String?            @db.Uuid
  createdByName     String?
  executedById      String?            @db.Uuid
  executedByName    String?
  executedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([windowFrom, windowTo])
  @@index([status])
  @@index([createdById])
}

model FiscalInvoice {
  id            String          @id @default(uuid()) @db.Uuid
  kind          FiscalInvoiceKind
  invoiceDate   DateTime
  imageUrl      String
  note          String?
  createdById   String?         @db.Uuid
  createdByName String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([kind])
  @@index([invoiceDate])
  @@index([createdById])
}

model PayableService {
  id            String             @id @default(uuid()) @db.Uuid
  title         String
  providerKind  PayableProviderKind
  providerName  String
  description   String?
  frequency     PayableFrequency
  defaultAmount Decimal?           @db.Decimal(12, 2)
  nextDueDate   DateTime
  lastPaidAt    DateTime?
  active        Boolean            @default(true)
  createdById   String?            @db.Uuid
  createdByName String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  payments PayablePayment[]

  @@index([active, nextDueDate])
  @@index([providerKind])
  @@index([createdById])
}

model PayablePayment {
  id            String   @id @default(uuid()) @db.Uuid
  serviceId     String   @db.Uuid
  amount        Decimal  @db.Decimal(12, 2)
  paidAt        DateTime @default(now())
  note          String?
  createdById   String?  @db.Uuid
  createdByName String?
  createdAt     DateTime @default(now())

  service PayableService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, paidAt])
  @@index([paidAt])
  @@index([createdById])
}

model PayrollEmployee {
  id        String   @id @default(uuid()) @db.Uuid
  ownerId   String   @db.Uuid
  userId    String?  @unique @db.Uuid @map("user_id")
  nombre    String
  telefono  String?
  puesto    String?
  salarioBaseQuincenal Decimal @default(0) @db.Decimal(12, 2)
  cuotaMinima Decimal @default(0) @db.Decimal(12, 2)
  seguroLeyMonto Decimal @default(0) @db.Decimal(12, 2)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation("PayrollOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  user User? @relation("PayrollEmployeeUser", fields: [userId], references: [id], onDelete: SetNull)
  configs PayrollEmployeeConfig[]
  entries PayrollEntry[]

  @@index([ownerId])
  @@index([userId])
  @@index([ownerId, nombre])
}

model PayrollPeriod {
  id        String              @id @default(uuid()) @db.Uuid
  ownerId   String              @db.Uuid
  title     String
  startDate DateTime
  endDate   DateTime
  status    PayrollPeriodStatus @default(OPEN)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  configs PayrollEmployeeConfig[]
  entries PayrollEntry[]

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([startDate, endDate])
}

model PayrollEmployeeConfig {
  id                 String   @id @default(uuid()) @db.Uuid
  ownerId            String   @db.Uuid
  periodId           String   @db.Uuid
  employeeId         String   @db.Uuid
  baseSalary         Decimal  @db.Decimal(12, 2)
  includeCommissions Boolean  @default(false)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  period PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([ownerId, periodId, employeeId])
  @@index([ownerId])
  @@index([periodId, employeeId])
}

model PayrollEntry {
  id         String           @id @default(uuid()) @db.Uuid
  ownerId    String           @db.Uuid
  periodId   String           @db.Uuid
  employeeId String           @db.Uuid
  pagoCombustibleTecnicoId String? @unique @db.Uuid @map("pago_combustible_tecnico_id")
  date       DateTime
  type       PayrollEntryType
  concept    String
  amount     Decimal          @db.Decimal(12, 2)
  cantidad   Decimal?         @db.Decimal(12, 2)
  createdAt  DateTime         @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  period PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  pagoCombustibleTecnico PagoCombustibleTecnico? @relation(fields: [pagoCombustibleTecnicoId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([periodId, employeeId])
  @@index([pagoCombustibleTecnicoId])
  @@index([date])
}

model Service {
  id                      String        @id @default(uuid()) @db.Uuid
  customerId              String        @db.Uuid
  createdByUserId         String        @db.Uuid
  serviceType             ServiceType
  category                String
  status                  ServiceStatus @default(RESERVED)
  currentPhase             ServicePhaseType @default(RESERVA)
  orderType               OrderType     @default(RESERVA)
  orderState              OrderState    @default(PENDING)
  technicianId            String?       @db.Uuid
  priority                Int           @default(2)
  title                   String
  description             String
  quotedAmount            Decimal?      @db.Decimal(12, 2)
  depositAmount           Decimal?      @db.Decimal(12, 2)
  paymentStatus           String        @default("pending")
  addressSnapshot         String?
  orderExtras              Json?
  scheduledStart          DateTime?
  scheduledEnd            DateTime?
  completedAt             DateTime?
  warrantyParentServiceId String?       @db.Uuid
  tags                    String[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  isDeleted               Boolean       @default(false)

  customer Client   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User    @relation("ServiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  technician User?  @relation("ServiceTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  warrantyParent Service?  @relation("WarrantyParent", fields: [warrantyParentServiceId], references: [id], onDelete: SetNull)
  warrantyChildren Service[] @relation("WarrantyParent")
  assignments ServiceAssignment[]
  steps ServiceStep[]
  updates ServiceUpdate[]
  files ServiceFile[]
  phaseHistory ServicePhaseHistory[]

  salidasTecnicas SalidaTecnica[]

  @@index([customerId])
  @@index([createdByUserId])
  @@index([serviceType])
  @@index([status])
  @@index([currentPhase])
  @@index([orderType])
  @@index([orderState])
  @@index([technicianId])
  @@index([priority])
  @@index([scheduledStart])
  @@index([isDeleted])
}

model Vehiculo {
  id                 String   @id @default(uuid()) @db.Uuid
  nombre             String
  tipo               String
  marca              String?
  modelo             String?
  placa              String?
  combustibleTipo    String   @map("combustible_tipo")
  rendimientoKmLitro Decimal? @db.Decimal(10, 2) @map("rendimiento_km_litro")
  capacidadTanqueLitros Decimal? @db.Decimal(10, 2) @map("capacidad_tanque_litros")
  esEmpresa          Boolean  @default(false) @map("es_empresa")
  tecnicoIdPropietario String? @db.Uuid @map("tecnico_id_propietario")
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  propietario User? @relation("VehiculoPropietario", fields: [tecnicoIdPropietario], references: [id], onDelete: SetNull)
  salidas     SalidaTecnica[]

  @@index([esEmpresa])
  @@index([tecnicoIdPropietario])
  @@index([activo])
  @@map("vehiculos")
}

model PrecioCombustible {
  id              String   @id @default(uuid()) @db.Uuid
  combustibleTipo String   @map("combustible_tipo")
  precioPorLitro  Decimal  @db.Decimal(12, 2) @map("precio_por_litro")
  vigenciaDesde   DateTime? @map("vigencia_desde")
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([combustibleTipo])
  @@index([combustibleTipo, activo])
  @@index([vigenciaDesde])
  @@map("precios_combustible")
}

model PagoCombustibleTecnico {
  id          String                     @id @default(uuid()) @db.Uuid
  tecnicoId   String                     @db.Uuid @map("tecnico_id")
  fechaInicio DateTime                   @map("fecha_inicio")
  fechaFin    DateTime                   @map("fecha_fin")
  totalMonto  Decimal                    @db.Decimal(12, 2) @map("total_monto")
  estado      PagoCombustibleTecnicoEstado @default(PENDIENTE)
  fechaPago   DateTime?                  @map("fecha_pago")
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  tecnico User @relation(fields: [tecnicoId], references: [id], onDelete: Restrict)
  salidas SalidaTecnica[]
  payrollEntry PayrollEntry?

  @@unique([tecnicoId, fechaInicio, fechaFin])
  @@index([tecnicoId])
  @@index([createdAt])
  @@map("pagos_combustible_tecnicos")
}

model SalidaTecnica {
  id                    String            @id @default(uuid()) @db.Uuid
  servicioId            String            @db.Uuid @map("servicio_id")
  tecnicoId             String            @db.Uuid @map("tecnico_id")
  vehiculoId            String            @db.Uuid @map("vehiculo_id")
  pagoCombustibleId     String?           @db.Uuid @map("pago_combustible_id")

  esVehiculoPropio      Boolean           @default(false) @map("es_vehiculo_propio")
  generaPagoCombustible Boolean           @default(false) @map("genera_pago_combustible")

  fecha                 DateTime          @default(now())
  horaSalida            DateTime          @map("hora_salida")
  horaLlegada           DateTime?         @map("hora_llegada")
  horaFinal             DateTime?         @map("hora_final")

  latSalida             Float             @map("lat_salida")
  lngSalida             Float             @map("lng_salida")
  latLlegada            Float?            @map("lat_llegada")
  lngLlegada            Float?            @map("lng_llegada")
  latFinal              Float?            @map("lat_final")
  lngFinal              Float?            @map("lng_final")

  kmEstimados           Decimal?          @db.Decimal(12, 2) @map("km_estimados")
  litrosEstimados       Decimal?          @db.Decimal(12, 2) @map("litros_estimados")
  precioCombustibleLitro Decimal?         @db.Decimal(12, 2) @map("precio_combustible_litro")
  montoCombustible      Decimal           @default(0) @db.Decimal(12, 2) @map("monto_combustible")

  estado                SalidaTecnicaEstado @default(INICIADA)
  observacion           String?           @map("observacion")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  tecnico        User                   @relation(fields: [tecnicoId], references: [id], onDelete: Restrict)
  vehiculo       Vehiculo               @relation(fields: [vehiculoId], references: [id], onDelete: Restrict)
  servicio       Service                @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  pagoCombustible PagoCombustibleTecnico? @relation(fields: [pagoCombustibleId], references: [id], onDelete: SetNull)

  @@index([tecnicoId, fecha])
  @@index([servicioId])
  @@index([vehiculoId])
  @@index([estado])
  @@index([pagoCombustibleId])
  @@map("salidas_tecnicas")
}

model ServicePhaseHistory {
  id              String           @id @default(uuid()) @db.Uuid
  serviceId       String           @db.Uuid
  phase           ServicePhaseType
  note            String?
  changedByUserId String           @db.Uuid
  changedAt       DateTime         @default(now())
  fromPhase       ServicePhaseType?
  toPhase         ServicePhaseType?

  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([serviceId, changedAt])
  @@index([changedByUserId])
}

model ServiceAssignment {
  id         String                @id @default(uuid()) @db.Uuid
  serviceId  String                @db.Uuid
  userId     String                @db.Uuid
  role       ServiceAssignmentRole @default(ASSISTANT)
  assignedAt DateTime              @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([serviceId, userId])
  @@index([serviceId])
  @@index([userId])
}

model ServiceStep {
  id           String   @id @default(uuid()) @db.Uuid
  serviceId    String   @db.Uuid
  stepKey      String
  stepLabel    String
  isDone       Boolean  @default(false)
  doneAt       DateTime?
  doneByUserId String?  @db.Uuid

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  doneBy  User?   @relation("ServiceStepDoneBy", fields: [doneByUserId], references: [id], onDelete: SetNull)

  @@unique([serviceId, stepKey])
  @@index([serviceId])
}

model ServiceUpdate {
  id              String            @id @default(uuid()) @db.Uuid
  serviceId       String            @db.Uuid
  changedByUserId String            @db.Uuid
  type            ServiceUpdateType
  oldValue        Json?
  newValue        Json?
  message         String?
  createdAt       DateTime          @default(now())

  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([serviceId, createdAt])
  @@index([changedByUserId])
}

model ServiceFile {
  id               String   @id @default(uuid()) @db.Uuid
  serviceId        String   @db.Uuid
  uploadedByUserId String   @db.Uuid
  fileUrl          String
  fileType         String
  createdAt        DateTime @default(now())

  service    Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([serviceId])
  @@index([uploadedByUserId])
}

model Cotizacion {
  id              String   @id @default(uuid()) @db.Uuid
  createdByUserId String   @db.Uuid
  customerId      String?  @db.Uuid
  customerName    String
  customerPhone   String
  note            String?  
  includeItbis    Boolean  @default(false)
  itbisRate       Decimal  @default(0.18) @db.Decimal(5, 4)
  subtotal        Decimal  @db.Decimal(12, 2)
  itbisAmount     Decimal  @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User    @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  customer  Client? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items     CotizacionItem[]

  @@index([createdByUserId])
  @@index([customerId])
  @@index([customerPhone])
  @@index([createdAt])
}

model CotizacionItem {
  id                   String   @id @default(uuid()) @db.Uuid
  cotizacionId         String   @db.Uuid
  productId            String?  @db.Uuid
  productNameSnapshot  String
  productImageSnapshot String?
  qty                  Decimal  @db.Decimal(12, 3)
  unitPrice            Decimal  @db.Decimal(12, 2)
  lineTotal            Decimal  @db.Decimal(12, 2)
  createdAt            DateTime @default(now())

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  product   Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([cotizacionId])
  @@index([productId])
}

model WorkScheduleProfile {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  days WorkScheduleProfileDay[]
  employeeConfigs WorkEmployeeConfig[]

  @@index([isDefault])
  @@map("work_schedule_profiles")
}

model WorkScheduleProfileDay {
  id          String        @id @default(uuid()) @db.Uuid
  profileId   String        @db.Uuid @map("profile_id")
  weekday     Int           // 0=Mon ... 6=Sun
  isWorking   Boolean       @default(true) @map("is_working")
  kind        WorkShiftKind @default(NORMAL)
  startMinute Int           @map("start_minute")
  endMinute   Int           @map("end_minute")

  profile WorkScheduleProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, weekday])
  @@index([weekday])
  @@map("work_schedule_profile_days")
}

model WorkCoverageRule {
  id          String   @id @default(uuid()) @db.Uuid
  role        Role
  weekday     Int      // 0=Mon ... 6=Sun
  minRequired Int      @default(0) @map("min_required")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([role, weekday])
  @@index([weekday])
  @@map("work_coverage_rules")
}

model WorkEmployeeConfig {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @unique @db.Uuid @map("user_id")
  enabled                Boolean  @default(true)
  scheduleProfileId      String?  @db.Uuid @map("schedule_profile_id")
  preferredDayOffWeekday Int?     @map("preferred_day_off_weekday")
  fixedDayOffWeekday     Int?     @map("fixed_day_off_weekday")
  disallowedDayOffWeekdays Int[]  @default([]) @map("disallowed_day_off_weekdays")
  unavailableWeekdays    Int[]    @default([]) @map("unavailable_weekdays")
  notes                  String?
  lastAssignedDayOffWeekday Int?  @map("last_assigned_day_off_weekday")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleProfile WorkScheduleProfile? @relation(fields: [scheduleProfileId], references: [id], onDelete: SetNull)
  exceptions WorkScheduleException[]
  assignments WorkDayAssignment[]

  @@index([enabled])
  @@index([scheduleProfileId])
  @@map("work_employee_configs")
}

model WorkScheduleException {
  id          String                    @id @default(uuid()) @db.Uuid
  userId      String?                   @db.Uuid @map("user_id")
  type        WorkScheduleExceptionType
  dateFrom    DateTime                  @map("date_from")
  dateTo      DateTime                  @map("date_to")
  note        String?
  createdById String?                   @db.Uuid @map("created_by_id")
  createdByName String?                 @map("created_by_name")
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  employeeConfig WorkEmployeeConfig? @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([dateFrom, dateTo])
  @@map("work_schedule_exceptions")
}

model WorkWeekSchedule {
  id            String                @id @default(uuid()) @db.Uuid
  weekStartDate DateTime              @unique @map("week_start_date")
  status        WorkWeekScheduleStatus @default(GENERATED)
  generatedById String?               @db.Uuid @map("generated_by_id")
  generatedByName String?             @map("generated_by_name")
  generatedAt   DateTime              @default(now()) @map("generated_at")
  warnings      Json?                 // array of strings/objects
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  days WorkDayAssignment[]

  @@index([generatedAt])
  @@map("work_week_schedules")
}

model WorkDayAssignment {
  id            String               @id @default(uuid()) @db.Uuid
  weekScheduleId String              @db.Uuid @map("week_schedule_id")
  userId        String               @db.Uuid @map("user_id")
  date          DateTime
  weekday       Int
  status        WorkAssignmentStatus
  startMinute   Int?                 @map("start_minute")
  endMinute     Int?                 @map("end_minute")
  manualOverride Boolean             @default(false) @map("manual_override")
  note          String?
  conflictFlags Json?                @map("conflict_flags")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  weekSchedule WorkWeekSchedule @relation(fields: [weekScheduleId], references: [id], onDelete: Cascade)
  employeeConfig WorkEmployeeConfig @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([weekScheduleId, userId, date])
  @@index([weekScheduleId])
  @@index([userId])
  @@index([date])
  @@index([weekday])
  @@map("work_day_assignments")
}

model WorkScheduleAuditLog {
  id            String                 @id @default(uuid()) @db.Uuid
  action        WorkScheduleAuditAction
  actorUserId   String?                @db.Uuid @map("actor_user_id")
  actorUserName String?                @map("actor_user_name")
  targetUserId  String?                @db.Uuid @map("target_user_id")
  weekStartDate DateTime?              @map("week_start_date")
  dateAffected  DateTime?              @map("date_affected")
  reason        String?
  before        Json?
  after         Json?
  createdAt     DateTime               @default(now())

  @@index([action])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([weekStartDate])
  @@index([createdAt])
  @@map("work_schedule_audit_logs")
}
