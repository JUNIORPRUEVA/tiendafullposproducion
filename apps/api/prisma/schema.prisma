  @@index([windowFrom, windowTo])
  @@index([status])
  @@index([createdById])
  @@index([correctionOfDepositOrderId])
  @@index([deletedById])
}

model FiscalInvoice {
  id            String          @id @default(uuid()) @db.Uuid
  kind          FiscalInvoiceKind
  invoiceDate   DateTime
  imageUrl      String
  note          String?
  createdById   String?         @db.Uuid
  createdByName String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([kind])
  @@index([invoiceDate])
  @@index([createdById])
}

model PayableService {
  id            String             @id @default(uuid()) @db.Uuid
  title         String
  providerKind  PayableProviderKind
  providerName  String
  description   String?
  frequency     PayableFrequency
  defaultAmount Decimal?           @db.Decimal(12, 2)
  nextDueDate   DateTime
  lastPaidAt    DateTime?
  active        Boolean            @default(true)
  createdById   String?            @db.Uuid
  createdByName String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  payments PayablePayment[]

  @@index([active, nextDueDate])
  @@index([providerKind])
  @@index([createdById])
}

model PayablePayment {
  id            String   @id @default(uuid()) @db.Uuid
  serviceId     String   @db.Uuid
  amount        Decimal  @db.Decimal(12, 2)
  paidAt        DateTime @default(now())
  note          String?
  createdById   String?  @db.Uuid
  createdByName String?
  createdAt     DateTime @default(now())

  service PayableService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, paidAt])
  @@index([paidAt])
  @@index([createdById])
}

model PayrollEmployee {
  id        String   @id @default(uuid()) @db.Uuid
  ownerId   String   @db.Uuid
  userId    String?  @unique @db.Uuid @map("user_id")
  nombre    String
  telefono  String?
  puesto    String?
  salarioBaseQuincenal Decimal @default(0) @db.Decimal(12, 2)
  cuotaMinima Decimal @default(0) @db.Decimal(12, 2)
  seguroLeyMonto Decimal @default(0) @db.Decimal(12, 2)
  seguroLeyMontoLocked Boolean @default(false) @map("seguro_ley_monto_locked")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation("PayrollOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  user User? @relation("PayrollEmployeeUser", fields: [userId], references: [id], onDelete: SetNull)
  configs PayrollEmployeeConfig[]
  entries PayrollEntry[]
  periodStatuses PayrollEmployeePeriodStatus[]
  serviceCommissionRequests PayrollServiceCommissionRequest[]

  @@index([ownerId])
  @@index([userId])
  @@index([ownerId, nombre])
}

model PayrollPeriod {
  id        String              @id @default(uuid()) @db.Uuid
  ownerId   String              @db.Uuid
  title     String
  startDate DateTime
  endDate   DateTime
  status    PayrollPeriodStatus @default(OPEN)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  configs PayrollEmployeeConfig[]
  entries PayrollEntry[]
  employeeStatuses PayrollEmployeePeriodStatus[]
  serviceCommissionRequests PayrollServiceCommissionRequest[]

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([startDate, endDate])
}

model PayrollEmployeeConfig {
  id                 String   @id @default(uuid()) @db.Uuid
  ownerId            String   @db.Uuid
  periodId           String   @db.Uuid
  employeeId         String   @db.Uuid
  baseSalary         Decimal  @db.Decimal(12, 2)
  includeCommissions Boolean  @default(false)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  period PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([ownerId, periodId, employeeId])
  @@index([ownerId])
  @@index([periodId, employeeId])
}

model PayrollEntry {
  id         String           @id @default(uuid()) @db.Uuid
  ownerId    String           @db.Uuid
  periodId   String           @db.Uuid
  employeeId String           @db.Uuid
  pagoCombustibleTecnicoId String? @unique @db.Uuid @map("pago_combustible_tecnico_id")
  date       DateTime
  type       PayrollEntryType
  concept    String
  amount     Decimal          @db.Decimal(12, 2)
  cantidad   Decimal?         @db.Decimal(12, 2)
  createdAt  DateTime         @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  period PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  pagoCombustibleTecnico PagoCombustibleTecnico? @relation(fields: [pagoCombustibleTecnicoId], references: [id], onDelete: SetNull)
  payrollServiceCommissionRequest PayrollServiceCommissionRequest? @relation("PayrollServiceCommissionRequestToEntry")

  @@index([ownerId])
  @@index([periodId, employeeId])
  @@index([pagoCombustibleTecnicoId])
  @@index([date])
}

model PayrollEmployeePeriodStatus {
  id         String               @id @default(uuid()) @db.Uuid
  ownerId    String               @db.Uuid
  periodId   String               @db.Uuid
  employeeId String               @db.Uuid
  status     PayrollPaymentStatus @default(DRAFT)
  paidAt     DateTime?
  paidById   String?              @db.Uuid
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  period PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employee PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([ownerId, periodId, employeeId])
  @@index([ownerId])
  @@index([periodId, employeeId])
  @@index([status])
}

model PayrollServiceCommissionRequest {
  id            String                         @id @default(uuid()) @db.Uuid
  ownerId       String                         @db.Uuid
  serviceOrderId String                        @unique @db.Uuid @map("service_order_id")
  quotationId   String?                        @db.Uuid @map("quotation_id")
  employeeId    String                         @db.Uuid @map("employee_id")
  technicianUserId String                      @db.Uuid @map("technician_user_id")
  createdByUserId String?                      @db.Uuid @map("created_by_user_id")
  reviewedByUserId String?                     @db.Uuid @map("reviewed_by_user_id")
  periodId      String?                        @db.Uuid @map("period_id")
  payrollEntryId String?                       @unique @db.Uuid @map("payroll_entry_id")
  serviceType   ServiceOrderType               @map("service_type")
  finalizedAt   DateTime                       @map("finalized_at")
  profitAfterExpense Decimal                   @db.Decimal(12, 2) @map("profit_after_expense")
  commissionRate Decimal                       @db.Decimal(5, 4) @default(0.1000) @map("commission_rate")
  commissionAmount Decimal                     @db.Decimal(12, 2) @map("commission_amount")
  concept       String
  status        PayrollServiceCommissionStatus @default(PENDING)
  reviewNote    String?                        @map("review_note")
  approvedAt    DateTime?                      @map("approved_at")
  rejectedAt    DateTime?                      @map("rejected_at")
  createdAt     DateTime                       @default(now()) @map("created_at")
  updatedAt     DateTime                       @updatedAt @map("updated_at")

  owner User @relation("PayrollServiceCommissionOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  employee PayrollEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period PayrollPeriod? @relation(fields: [periodId], references: [id], onDelete: SetNull)
  payrollEntry PayrollEntry? @relation("PayrollServiceCommissionRequestToEntry", fields: [payrollEntryId], references: [id], onDelete: SetNull)
  technicianUser User @relation("PayrollServiceCommissionTechnicianUser", fields: [technicianUserId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("PayrollServiceCommissionCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reviewedByUser User? @relation("PayrollServiceCommissionReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([employeeId, status])
  @@index([technicianUserId, status])
  @@index([finalizedAt])
  @@index([periodId])
  @@map("payroll_service_commission_requests")
}

model CompanyManualEntry {
  id              String                @id @default(uuid()) @db.Uuid
  ownerId         String                @db.Uuid
  title           String
  summary         String?
  content         String
  kind            CompanyManualEntryKind
  audience        CompanyManualAudience @default(GENERAL)
  targetRoles     Role[]                @default([])
  moduleKey       String?
  published       Boolean               @default(true)
  sortOrder       Int                   @default(0)
  createdByUserId String                @db.Uuid
  updatedByUserId String?               @db.Uuid
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([ownerId])
  @@index([ownerId, published])
  @@index([ownerId, kind])
  @@index([ownerId, audience])
  @@index([updatedAt])
}

model Service {
  id                      String        @id @default(uuid()) @db.Uuid
  // Short human-friendly order number (e.g. YYYYMMDDHHmmssSSSxx). Nullable for backward compatibility.
  orderNumber             String?       @unique
  customerId              String        @db.Uuid
  createdByUserId         String        @db.Uuid
  serviceType             ServiceType
  category                String
  categoryId              String?       @db.Uuid @map("category_id")
  status                  ServiceStatus @default(RESERVED)
  currentPhase             ServicePhaseType @default(RESERVA)
  orderType               OrderType     @default(RESERVA)
  orderState              OrderState    @default(PENDING)

  // Admin-only: separate flow phase + operational status.
  // Nullable for backward compatibility (existing rows).
  adminPhase              AdminOrderPhase?
  adminStatus             AdminOrderStatus?
  technicianId            String?       @db.Uuid
  priority                Int           @default(2)
  title                   String
  description             String
  quotedAmount            Decimal?      @db.Decimal(12, 2)
  depositAmount           Decimal?      @db.Decimal(12, 2)
  paymentStatus           String        @default("pending")
  addressSnapshot         String?
  orderExtras              Json?
  scheduledStart          DateTime?
  scheduledEnd            DateTime?
  completedAt             DateTime?
  warrantyParentServiceId String?       @db.Uuid
  tags                    String[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  isDeleted               Boolean       @default(false)

  customer Client   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  categoryRef ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User    @relation("ServiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  technician User?  @relation("ServiceTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  warrantyParent Service?  @relation("WarrantyParent", fields: [warrantyParentServiceId], references: [id], onDelete: SetNull)
  warrantyChildren Service[] @relation("WarrantyParent")
  assignments ServiceAssignment[]
  steps ServiceStep[]
  updates ServiceUpdate[]
  files ServiceFile[]
  phaseHistory ServicePhaseHistory[]
  executionReports ServiceExecutionReport[]
  executionChanges ServiceExecutionChange[]
  checklistExecutions ChecklistExecution[]

  closing ServiceClosing?
  technicalVisit TechnicalVisit? @relation("ServiceTechnicalVisit")

  salidasTecnicas SalidaTecnica[]

  @@index([customerId])
  @@index([createdByUserId])
  @@index([serviceType])
  @@index([status])
  @@index([categoryId])
  @@index([currentPhase])
  @@index([orderType])
  @@index([orderState])
  @@index([adminPhase])
  @@index([adminStatus])
  @@index([technicianId])
  @@index([priority])
  @@index([scheduledStart])
  @@index([isDeleted])
}

model ServiceClosing {
  id        String   @id @default(uuid()) @db.Uuid
  serviceId String   @unique @db.Uuid

  // Draft/editable data snapshots.
  invoiceData  Json?
  warrantyData Json?

  // Files (stored as ServiceFile records).
  invoiceDraftFileId   String? @db.Uuid
  warrantyDraftFileId  String? @db.Uuid
  invoiceApprovedFileId  String? @db.Uuid
  warrantyApprovedFileId String? @db.Uuid
  invoiceFinalFileId   String? @db.Uuid
  warrantyFinalFileId  String? @db.Uuid

  approvalStatus ServiceClosingApprovalStatus @default(PENDING)
  approvedByUserId String? @db.Uuid
  approvedAt        DateTime?
  rejectedByUserId  String? @db.Uuid
  rejectedAt        DateTime?
  rejectReason      String?

  signatureStatus ServiceClosingSignatureStatus @default(PENDING)
  signatureFileId String? @db.Uuid
  signedAt        DateTime?

  sentToTechnicianAt DateTime?
  sentToClientAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  approvedBy User? @relation("ServiceClosingApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectedBy User? @relation("ServiceClosingRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)

  signatureFile ServiceFile? @relation("ServiceClosingSignatureFile", fields: [signatureFileId], references: [id], onDelete: SetNull)

  invoiceDraftFile ServiceFile? @relation("ServiceClosingInvoiceDraftFile", fields: [invoiceDraftFileId], references: [id], onDelete: SetNull)
  warrantyDraftFile ServiceFile? @relation("ServiceClosingWarrantyDraftFile", fields: [warrantyDraftFileId], references: [id], onDelete: SetNull)
  invoiceApprovedFile ServiceFile? @relation("ServiceClosingInvoiceApprovedFile", fields: [invoiceApprovedFileId], references: [id], onDelete: SetNull)
  warrantyApprovedFile ServiceFile? @relation("ServiceClosingWarrantyApprovedFile", fields: [warrantyApprovedFileId], references: [id], onDelete: SetNull)
  invoiceFinalFile ServiceFile? @relation("ServiceClosingInvoiceFinalFile", fields: [invoiceFinalFileId], references: [id], onDelete: SetNull)
  warrantyFinalFile ServiceFile? @relation("ServiceClosingWarrantyFinalFile", fields: [warrantyFinalFileId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([approvalStatus])
  @@index([signatureStatus])
  @@index([approvedAt])
  @@index([signedAt])
}

model WarrantyProductConfig {
  id                String               @id @default(uuid()) @db.Uuid
  ownerId           String               @db.Uuid @map("owner_id")
  categoryId        String?              @db.Uuid @map("category_id")
  categoryCode      String?              @map("category_code")
  categoryName      String?              @map("category_name")
  productName       String?              @map("product_name")
  productKey        String?              @map("product_key")
  hasWarranty       Boolean              @default(true) @map("has_warranty")
  durationValue     Int?                 @map("duration_value")
  durationUnit      WarrantyDurationUnit? @map("duration_unit")
  warrantySummary   String?              @db.Text @map("warranty_summary")
  coverageSummary   String?              @db.Text @map("coverage_summary")
  exclusionsSummary String?              @db.Text @map("exclusions_summary")
  notes             String?              @db.Text
  isActive          Boolean              @default(true) @map("is_active")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  owner    User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  category ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([ownerId, isActive])
  @@index([ownerId, categoryId])
  @@index([ownerId, categoryCode])
  @@index([ownerId, productKey])
  @@map("warranty_product_configs")
}

model TechnicalVisit {
  id                 String   @id @default(uuid()) @db.Uuid
  orderId            String   @unique @db.Uuid @map("order_id")
  technicianId       String   @db.Uuid @map("technician_id")

  reportDescription  String   @db.Text @map("report_description")
  installationNotes  String   @db.Text @map("installation_notes")

  estimatedProducts  Json     @default(dbgenerated("'[]'::jsonb")) @map("estimated_products")
  photos             Json     @default(dbgenerated("'[]'::jsonb"))
  videos             Json     @default(dbgenerated("'[]'::jsonb"))

  visitDate          DateTime @default(now()) @map("visit_date")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  order              Service  @relation("ServiceTechnicalVisit", fields: [orderId], references: [id], onDelete: Cascade)
  technician         User     @relation("TechnicalVisitTechnician", fields: [technicianId], references: [id], onDelete: Restrict)

  @@index([technicianId])
  @@map("technical_visits")
}

model Vehiculo {
  id                 String   @id @default(uuid()) @db.Uuid
  nombre             String
  tipo               String
  marca              String?
  modelo             String?
  placa              String?
  combustibleTipo    String   @map("combustible_tipo")
  rendimientoKmLitro Decimal? @db.Decimal(10, 2) @map("rendimiento_km_litro")
  capacidadTanqueLitros Decimal? @db.Decimal(10, 2) @map("capacidad_tanque_litros")
  esEmpresa          Boolean  @default(false) @map("es_empresa")
  tecnicoIdPropietario String? @db.Uuid @map("tecnico_id_propietario")
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  propietario User? @relation("VehiculoPropietario", fields: [tecnicoIdPropietario], references: [id], onDelete: SetNull)
  salidas     SalidaTecnica[]

  @@index([esEmpresa])
  @@index([tecnicoIdPropietario])
  @@index([activo])
  @@map("vehiculos")
}

model PrecioCombustible {
  id              String   @id @default(uuid()) @db.Uuid
  combustibleTipo String   @map("combustible_tipo")
  precioPorLitro  Decimal  @db.Decimal(12, 2) @map("precio_por_litro")
  vigenciaDesde   DateTime? @map("vigencia_desde")
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([combustibleTipo])
  @@index([combustibleTipo, activo])
  @@index([vigenciaDesde])
  @@map("precios_combustible")
}

model PagoCombustibleTecnico {
  id          String                     @id @default(uuid()) @db.Uuid
  tecnicoId   String                     @db.Uuid @map("tecnico_id")
  fechaInicio DateTime                   @map("fecha_inicio")
  fechaFin    DateTime                   @map("fecha_fin")
  totalMonto  Decimal                    @db.Decimal(12, 2) @map("total_monto")
  estado      PagoCombustibleTecnicoEstado @default(PENDIENTE)
  fechaPago   DateTime?                  @map("fecha_pago")
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  tecnico User @relation(fields: [tecnicoId], references: [id], onDelete: Restrict)
  salidas SalidaTecnica[]
  payrollEntry PayrollEntry?

  @@unique([tecnicoId, fechaInicio, fechaFin])
  @@index([tecnicoId])
  @@index([createdAt])
  @@map("pagos_combustible_tecnicos")
}

model SalidaTecnica {
  id                    String            @id @default(uuid()) @db.Uuid
  servicioId            String            @db.Uuid @map("servicio_id")
  tecnicoId             String            @db.Uuid @map("tecnico_id")
  vehiculoId            String            @db.Uuid @map("vehiculo_id")
  pagoCombustibleId     String?           @db.Uuid @map("pago_combustible_id")

  esVehiculoPropio      Boolean           @default(false) @map("es_vehiculo_propio")
  generaPagoCombustible Boolean           @default(false) @map("genera_pago_combustible")

  fecha                 DateTime          @default(now())
  horaSalida            DateTime          @map("hora_salida")
  horaLlegada           DateTime?         @map("hora_llegada")
  horaFinal             DateTime?         @map("hora_final")

  latSalida             Float             @map("lat_salida")
  lngSalida             Float             @map("lng_salida")
  latLlegada            Float?            @map("lat_llegada")
  lngLlegada            Float?            @map("lng_llegada")
  latFinal              Float?            @map("lat_final")
  lngFinal              Float?            @map("lng_final")

  kmEstimados           Decimal?          @db.Decimal(12, 2) @map("km_estimados")
  litrosEstimados       Decimal?          @db.Decimal(12, 2) @map("litros_estimados")
  precioCombustibleLitro Decimal?         @db.Decimal(12, 2) @map("precio_combustible_litro")
  montoCombustible      Decimal           @default(0) @db.Decimal(12, 2) @map("monto_combustible")

  estado                SalidaTecnicaEstado @default(INICIADA)
  observacion           String?           @map("observacion")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  tecnico        User                   @relation(fields: [tecnicoId], references: [id], onDelete: Restrict)
  vehiculo       Vehiculo               @relation(fields: [vehiculoId], references: [id], onDelete: Restrict)
  servicio       Service                @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  pagoCombustible PagoCombustibleTecnico? @relation(fields: [pagoCombustibleId], references: [id], onDelete: SetNull)

  @@index([tecnicoId, fecha])
  @@index([servicioId])
  @@index([vehiculoId])
  @@index([estado])
  @@index([pagoCombustibleId])
  @@map("salidas_tecnicas")
}

model ServicePhaseHistory {
  id              String           @id @default(uuid()) @db.Uuid
  serviceId       String           @db.Uuid
  phase           ServicePhaseType
  note            String?
  changedByUserId String           @db.Uuid
  changedAt       DateTime         @default(now())
  fromPhase       ServicePhaseType?
  toPhase         ServicePhaseType?

  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([serviceId, changedAt])
  @@index([changedByUserId])
}

model ServiceAssignment {
  id         String                @id @default(uuid()) @db.Uuid
  serviceId  String                @db.Uuid
  userId     String                @db.Uuid
  role       ServiceAssignmentRole @default(ASSISTANT)
  assignedAt DateTime              @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([serviceId, userId])
  @@index([serviceId])
  @@index([userId])
}

model ServiceStep {
  id           String   @id @default(uuid()) @db.Uuid
  serviceId    String   @db.Uuid
  stepKey      String
  stepLabel    String
  isDone       Boolean  @default(false)
  doneAt       DateTime?
  doneByUserId String?  @db.Uuid

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  doneBy  User?   @relation("ServiceStepDoneBy", fields: [doneByUserId], references: [id], onDelete: SetNull)

  @@unique([serviceId, stepKey])
  @@index([serviceId])
}

model ServiceUpdate {
  id              String            @id @default(uuid()) @db.Uuid
  serviceId       String            @db.Uuid
  changedByUserId String            @db.Uuid
  type            ServiceUpdateType
  oldValue        Json?
  newValue        Json?
  message         String?
  createdAt       DateTime          @default(now())

  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  changedBy User    @relation(fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([serviceId, createdAt])
  @@index([changedByUserId])
}

model ServiceFile {
  id               String   @id @default(uuid()) @db.Uuid
  serviceId        String   @db.Uuid
  uploadedByUserId String   @db.Uuid
  fileUrl          String
  fileType         String
  caption          String?
  storageProvider  String   @default("LOCAL")
  objectKey        String?
  originalFileName String?
  mimeType         String?
  mediaType        String?
  kind             String?
  fileSize         Int?
  width            Int?
  height           Int?
  durationSeconds  Int?
  executionReportId String? @db.Uuid
  deletedAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  service    Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
