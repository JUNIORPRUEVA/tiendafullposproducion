model CrmCommercialActivity {
  id               String    @id @default(uuid()) @db.Uuid
  customerId       String    @map("cliente_id") @db.Uuid
  createdByUserId  String    @map("creado_por_usuario_id") @db.Uuid
  assignedToUserId String?   @map("asignado_usuario_id") @db.Uuid
  activityType     String    @map("tipo")
  description      String    @map("descripcion") @db.Text
  dueAt            DateTime? @map("fecha_programada")
  completedAt      DateTime? @map("fecha_completada")
  createdAt        DateTime  @default(now()) @map("fecha_creacion")
  updatedAt        DateTime  @updatedAt @map("fecha_actualizacion")

  customer       CrmCommercialCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdByUser  User                  @relation("CrmCommercialActivityCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignedToUser User?                 @relation("CrmCommercialActivityAssignedToUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@index([assignedToUserId])
  @@map("crm_commercial_activities")
}

model CrmCommercialFollowupTask {
  id                String                             @id @default(uuid()) @db.Uuid
  customerId        String                             @map("cliente_id") @db.Uuid
  title             String                             @map("titulo")
  description       String?                            @map("descripcion") @db.Text
  dueDate           DateTime?                          @map("fecha_vencimiento")
  status            CrmCommercialFollowupTaskStatus    @default(PENDIENTE) @map("estado")
  priority          CrmCommercialFollowupTaskPriority  @default(NORMAL) @map("prioridad")
  assignedUserId    String?                            @map("asignado_usuario_id") @db.Uuid
  createdByUserId   String                             @map("creado_por_usuario_id") @db.Uuid
  completedAt       DateTime?                          @map("completado_en")
  completedByUserId String?                            @map("completado_por_usuario_id") @db.Uuid
  createdAt         DateTime                           @default(now()) @map("fecha_creacion")
  updatedAt         DateTime                           @updatedAt @map("fecha_actualizacion")

  customer         CrmCommercialCustomer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedUser     User?                               @relation("CrmFollowupTaskAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdByUser    User                                @relation("CrmFollowupTaskCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  completedByUser  User?                               @relation("CrmFollowupTaskCompletedByUser", fields: [completedByUserId], references: [id], onDelete: SetNull)

  @@index([customerId, status])
  @@index([assignedUserId])
  @@index([dueDate])
  @@index([status, dueDate])
  @@map("crm_commercial_followup_tasks")
}

model CrmCommercialSetting {
  id                         String   @id @default("global")
  selectedWhatsappInstanceId String?  @map("selected_whatsapp_instance_id")
  selectedWhatsappInstanceName String? @map("selected_whatsapp_instance_name")
  enabled                    Boolean  @default(false)
  updatedByUserId            String?  @map("updated_by_user_id") @db.Uuid
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  updatedByUser User? @relation("CrmCommercialSettingsUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("crm_commercial_settings")
}

model CrmCommercialLibraryItem {
  id              String                       @id @default(uuid()) @db.Uuid
  companyId       String                       @map("company_id") @db.Uuid
  title           String
  description     String?                      @db.Text
  type            CrmCommercialLibraryItemType
  contentText     String?                      @map("content_text") @db.Text
  mediaUrl        String?                      @map("media_url") @db.Text
  fileName        String?                      @map("file_name")
  mimeType        String?                      @map("mime_type")
  latitude        Decimal?                     @db.Decimal(10, 7)
  longitude       Decimal?                     @db.Decimal(10, 7)
  externalUrl     String?                      @map("external_url") @db.Text
  category        String?
  tags            String[]                     @default([])
  isActive        Boolean                      @default(true) @map("is_active")
  sortOrder       Int                          @default(0) @map("sort_order")
  createdByUserId String                       @map("created_by_user_id") @db.Uuid
  updatedByUserId String                       @map("updated_by_user_id") @db.Uuid
  useCount        Int                          @default(0) @map("use_count")
  lastUsedAt      DateTime?                    @map("last_used_at")
  createdAt       DateTime                     @default(now()) @map("created_at")
  updatedAt       DateTime                     @updatedAt @map("updated_at")

  createdByUser   User                         @relation("CrmCommercialLibraryCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser   User                         @relation("CrmCommercialLibraryUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, isActive, sortOrder])
  @@index([companyId, type, isActive])
  @@index([companyId, category, isActive])
  @@map("crm_commercial_library_items")
}

model Sale {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  customerId       String?   @db.Uuid
  saleDate         DateTime  @default(now())
  note             String?
  totalSold        Decimal   @db.Decimal(12, 2)
  totalCost        Decimal   @db.Decimal(12, 2)
  totalProfit      Decimal   @db.Decimal(12, 2)
  commissionRate   Decimal   @default(0.10) @db.Decimal(5, 4)
  commissionAmount Decimal   @db.Decimal(12, 2)
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?
  deletedById      String?   @db.Uuid
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer  Client?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  deletedBy User?     @relation("SaleDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  items     SaleItem[]

  @@index([userId])
  @@index([customerId])
  @@index([saleDate])
  @@index([isDeleted])
}

model SaleItem {
  id                   String   @id @default(uuid()) @db.Uuid
  saleId               String   @db.Uuid
  productId            String?  @db.Uuid
  productNameSnapshot  String
  productImageSnapshot String?
  qty                  Decimal  @db.Decimal(12, 3)
  priceSoldUnit        Decimal  @db.Decimal(12, 2)
  costUnitSnapshot     Decimal  @db.Decimal(12, 2)
  subtotalSold         Decimal  @db.Decimal(12, 2)
  subtotalCost         Decimal  @db.Decimal(12, 2)
  profit               Decimal  @db.Decimal(12, 2)
  createdAt            DateTime @default(now())

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([productId])
}

model Close {
  id            String    @id @default(uuid()) @db.Uuid
  type          CloseType
  date          DateTime  @default(now())
  status        String    @default("pending") // pending/approved/rejected
  cash          Decimal   @db.Decimal(12, 2)
  transfer      Decimal   @db.Decimal(12, 2)
  transferBank  String?
  card          Decimal   @db.Decimal(12, 2)
  otherIncome   Decimal   @default(0) @db.Decimal(12, 2)
  expenses      Decimal   @db.Decimal(12, 2)
  cashDelivered Decimal   @db.Decimal(12, 2)
  totalIncome   Decimal   @default(0) @db.Decimal(12, 2)
  netTotal      Decimal   @default(0) @db.Decimal(12, 2)
  difference    Decimal   @default(0) @db.Decimal(12, 2)
  notes         String?
  evidenceUrl        String?
  evidenceFileName   String?
  evidenceStorageKey String?
  evidenceMimeType   String?
  expenseDetails     Json?
  pdfUrl        String?
  pdfStorageKey String?
  pdfFileName   String?
  notificationStatus String?
  notificationError  String?
  createdById   String?   @db.Uuid
  createdByName String?
  reviewedById  String?   @db.Uuid
  reviewedByName String?
  reviewedAt    DateTime?
  reviewNote    String?
  aiRiskLevel   String?
  aiReportSummary String?
  aiReportJson  Json?
  aiGeneratedAt DateTime?
  correctionOfCloseId String? @db.Uuid
  correctionReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  transfers     CloseTransfer[]
  correctionOf  Close?    @relation("CloseCorrections", fields: [correctionOfCloseId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  corrections    Close[]   @relation("CloseCorrections")

  @@index([date])
  @@index([type])
  @@index([status])
  @@index([createdById])
  @@index([reviewedById])
  @@index([correctionOfCloseId])
}

model CloseTransfer {
  id              String                 @id @default(uuid()) @db.Uuid
  closeId         String                 @db.Uuid
  bankName        String
  amount          Decimal                @db.Decimal(12, 2)
  referenceNumber String?
  note            String?
  createdAt       DateTime               @default(now())
  close           Close                  @relation(fields: [closeId], references: [id], onDelete: Cascade)
  vouchers        CloseTransferVoucher[]

  @@index([closeId])
}

model CloseTransferVoucher {
  id         String        @id @default(uuid()) @db.Uuid
  transferId String        @db.Uuid
  storageKey String
  fileUrl    String
  fileName   String
  mimeType   String
  createdAt  DateTime      @default(now())
  transfer   CloseTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
}

model DepositOrder {
  id                String             @id @default(uuid()) @db.Uuid
  windowFrom        DateTime
  windowTo          DateTime
  bankName          String
  bankAccount       String?
  collaboratorName  String?
  note              String?
  reserveAmount     Decimal            @db.Decimal(12, 2)
  totalAvailableCash Decimal           @db.Decimal(12, 2)
  depositTotal      Decimal            @db.Decimal(12, 2)
  closesCountByType Json
  depositByType     Json
  accountByType     Json
  status            DepositOrderStatus @default(PENDING)
  voucherUrl        String?
  voucherFileName   String?
  voucherMimeType   String?
  createdById       String?            @db.Uuid
  createdByName     String?
  executedById      String?            @db.Uuid
  executedByName    String?
  executedAt        DateTime?
  correctionOfDepositOrderId String?   @db.Uuid
  correctionReason  String?
  deletedAt         DateTime?
  deletedById       String?            @db.Uuid
  deletedByName     String?
  deletedReason     String?
  createdAt         DateTime           @default(now())
