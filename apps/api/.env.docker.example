NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://fulltech:fulltech@db:5432/fulltech
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
CORS_ORIGIN=*
UPLOAD_DIR=/uploads
PUBLIC_BASE_URL=https://api.tu-dominio.com
# Nombre del volumen Docker para uploads (referencia): uploads_data
# Cambia en docker-compose si deseas otro nombre

# Storage (R2 / presigned uploads para evidencias de Operaciones)
# Requerido para /storage/presign + /storage/confirm.
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Opcional
STORAGE_PRESIGN_EXPIRES_SECONDS=900
STORAGE_IMAGE_MAX_BYTES=5242880
STORAGE_VIDEO_MAX_BYTES=20971520
STORAGE_DOCUMENT_MAX_BYTES=10485760

# Products (FULLPOS integration)
# Si deseas que el API lea productos desde FULLPOS, activa esta fuente y configura URL/TOKEN.
PRODUCTS_SOURCE=FULLPOS
FULLPOS_INTEGRATION_BASE_URL=https://<fullpos-backend-host>
FULLPOS_INTEGRATION_TOKEN=<fullpos-integration-token>
FULLPOS_INTEGRATION_TIMEOUT_MS=8000

# Seed (opcional)
ADMIN_EMAIL=admin@fulltech.local
ADMIN_PASSWORD=change-me
SELLER_PASSWORD=change-me
RUN_SEED=false

# Startup robustness (EasyPanel / contenedores)
RUN_MIGRATIONS=true
MIGRATION_MAX_RETRIES=10
MIGRATION_RETRY_DELAY_SECONDS=5
MIGRATION_STRICT=false
